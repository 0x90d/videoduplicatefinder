@page "/"
@rendermode InteractiveServer
@inject ScanService Scan
@inject FFmpegSetupService FFmpegSetup
@implements IDisposable

<PageTitle>Scan — Video Duplicate Finder</PageTitle>

<h1>Scan</h1>

@* FFmpeg setup banner *@
@if (FFmpegSetup.State == FFmpegSetupState.Checking) {
    <div class="ffmpeg-banner checking">
        <span class="spinner"></span>
        Checking FFmpeg availability...
    </div>
}
@if (FFmpegSetup.State == FFmpegSetupState.Downloading) {
    <div class="ffmpeg-banner downloading">
        <span class="spinner"></span>
        <span>@FFmpegSetup.StatusMessage</span>
        <div class="progress-bar-track inline-bar">
            <div class="progress-bar-fill" style="width:@FFmpegSetup.DownloadProgress.ToString("F0")%"></div>
        </div>
    </div>
}
@if (FFmpegSetup.State == FFmpegSetupState.DockerWarning) {
    <div class="ffmpeg-banner warning">
        <strong>FFmpeg not found</strong>
        <p>@FFmpegSetup.StatusMessage</p>
    </div>
}
@if (FFmpegSetup.State == FFmpegSetupState.Failed) {
    <div class="ffmpeg-banner failed">
        <div>
            <strong>FFmpeg download failed</strong>
            <p>@FFmpegSetup.StatusMessage</p>
        </div>
        <button @onclick="RetryFfmpegSetup">Retry</button>
    </div>
}

@if (Scan.State == ScanState.Error) {
    <div class="error-box">
        <strong>Error</strong>
        <p>@Scan.ErrorMessage</p>
        <button @onclick="Scan.Reset">Dismiss</button>
    </div>
}

@if (Scan.State == ScanState.Scanning || Scan.State == ScanState.Comparing || Scan.State == ScanState.RetrievingThumbnails) {
    <div class="progress-section">
        @if (Scan.State == ScanState.Scanning) {
            <p class="state-label">Hashing files...</p>
            @if (Scan.LastProgress is { } p && p.Max > 0) {
                int pct = (int)(100L * p.Current / p.Max);
                <div class="progress-bar-track">
                    <div class="progress-bar-fill" style="width:@pct%"></div>
                </div>
                <p>@p.Current / @p.Max &nbsp;|&nbsp; ETA @FormatEta(p.Remaining)</p>
                <p class="file-path">@TruncatePath(p.CurrentFile, 80)</p>
            }
        }
        else if (Scan.State == ScanState.Comparing) {
            <p class="state-label">
                <span class="spinner"></span>
                Comparing @(Scan.FilesHashed > 0 ? $"{Scan.FilesHashed:N0} hashed files" : "files") for duplicates...
            </p>
            <p class="comparing-note">This may take a while depending on library size.</p>
        }
        else {
            <p class="state-label">Retrieving thumbnails...</p>
            @if (Scan.ThumbnailMax > 0) {
                int pct = (int)(100L * Scan.ThumbnailCurrent / Scan.ThumbnailMax);
                <div class="progress-bar-track">
                    <div class="progress-bar-fill" style="width:@pct%"></div>
                </div>
                <p>@Scan.ThumbnailCurrent / @Scan.ThumbnailMax</p>
            }
        }
        <div class="actions">
            <button @onclick="Scan.Pause" disabled="@(Scan.State == ScanState.RetrievingThumbnails)">Pause</button>
            <button @onclick="Scan.Resume" disabled="@(Scan.State == ScanState.RetrievingThumbnails)">Resume</button>
            <button class="danger" @onclick="Scan.Stop">Stop</button>
        </div>
    </div>
}
else {
    <section class="scan-config">
        <h2>Include paths</h2>
        <div class="path-list">
            @foreach (var path in Scan.Settings.IncludeList.ToList()) {
                bool valid = Directory.Exists(path);
                <div class="path-entry">
                    <span class="path-status @(valid ? "valid" : "invalid")" title="@(valid ? "Accessible" : "Not found or not accessible")">@(valid ? "\u2713" : "\u2717")</span>
                    <span>@path</span>
                    <button @onclick="() => RemoveInclude(path)">&#x2715;</button>
                </div>
            }
        </div>
        <div class="add-path">
            <input @bind="_newInclude" @bind:event="oninput" @onkeydown="OnIncludeKeyDown"
                   placeholder="/path/to/scan" class="@PathInputClass(_newInclude)" />
            <button @onclick="AddInclude" disabled="@string.IsNullOrWhiteSpace(_newInclude)">Add</button>
            <button class="browse-btn" @onclick="() => _includeBrowser?.Open()">Browse…</button>
        </div>

        <h2>Exclude paths</h2>
        <div class="path-list">
            @foreach (var path in Scan.Settings.BlackList.ToList()) {
                bool valid = Directory.Exists(path);
                <div class="path-entry">
                    <span class="path-status @(valid ? "valid" : "invalid")" title="@(valid ? "Accessible" : "Not found")">@(valid ? "\u2713" : "\u2717")</span>
                    <span>@path</span>
                    <button @onclick="() => Scan.Settings.BlackList.Remove(path)">&#x2715;</button>
                </div>
            }
        </div>
        <div class="add-path">
            <input @bind="_newExclude" @bind:event="oninput" @onkeydown="OnExcludeKeyDown"
                   placeholder="/path/to/exclude" />
            <button @onclick="AddExclude" disabled="@string.IsNullOrWhiteSpace(_newExclude)">Add</button>
            <button class="browse-btn" @onclick="() => _excludeBrowser?.Open()">Browse…</button>
        </div>

        <FolderBrowser @ref="_includeBrowser" OnFolderSelected="OnIncludeFolderSelected" />
        <FolderBrowser @ref="_excludeBrowser" OnFolderSelected="OnExcludeFolderSelected" />

        <div class="start-row">
            @if (Scan.State == ScanState.Done || Scan.State == ScanState.Aborted || Scan.State == ScanState.Error) {
                <button @onclick="Scan.Reset">Reset</button>
            }
            <button @onclick="SaveSettings" title="Save current settings to disk">Save settings</button>
            <button class="primary" @onclick="Scan.StartScanAndCompare"
                    disabled="@(Scan.Settings.IncludeList.Count == 0 || !FFmpegSetup.IsReady)">
                Start Scan
            </button>
        </div>

        @if (_saveMsg != null) {
            <p class="@(_saveFailed ? "aborted-msg" : "done-msg")">@_saveMsg</p>
        }
        @if (Scan.State == ScanState.Done) {
            <p class="done-msg">Scan complete — <a href="/results">view @Scan.Duplicates.Count result(s)</a></p>
        }
        @if (Scan.State == ScanState.Aborted) {
            <p class="aborted-msg">Scan was stopped.</p>
        }
    </section>
}

@code {
    string _newInclude = string.Empty;
    string _newExclude = string.Empty;
    FolderBrowser? _includeBrowser;
    FolderBrowser? _excludeBrowser;
    string? _saveMsg;
    bool _saveFailed;

    protected override void OnInitialized() {
        Scan.StateChanged += OnStateChanged;
        FFmpegSetup.StateChanged += OnStateChanged;
    }

    void OnStateChanged() {
        try { _ = InvokeAsync(StateHasChanged); }
        catch { }
    }

    void RetryFfmpegSetup() => _ = FFmpegSetup.CheckAndSetupAsync();

    void AddInclude() {
        var path = _newInclude.Trim();
        if (!string.IsNullOrEmpty(path)) {
            Scan.Settings.IncludeList.Add(path);
            _newInclude = string.Empty;
        }
    }

    void OnIncludeFolderSelected(string path) {
        if (!Scan.Settings.IncludeList.Contains(path))
            Scan.Settings.IncludeList.Add(path);
    }

    void OnExcludeFolderSelected(string path) {
        if (!Scan.Settings.BlackList.Contains(path))
            Scan.Settings.BlackList.Add(path);
    }

    void RemoveInclude(string path) {
        Scan.Settings.IncludeList.Remove(path);
    }

    void AddExclude() {
        var path = _newExclude.Trim();
        if (!string.IsNullOrEmpty(path)) {
            Scan.Settings.BlackList.Add(path);
            _newExclude = string.Empty;
        }
    }

    void OnIncludeKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") AddInclude();
    }

    void OnExcludeKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") AddExclude();
    }

    string PathInputClass(string path) {
        if (string.IsNullOrWhiteSpace(path)) return string.Empty;
        return Directory.Exists(path.Trim()) ? "input-valid" : "input-invalid";
    }

    void SaveSettings() {
        bool ok = Scan.SaveSettings();
        _saveMsg = ok ? "Settings saved." : "Failed to save settings.";
        _saveFailed = !ok;
        _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => {
            _saveMsg = null;
            StateHasChanged();
        }));
    }

    static string FormatEta(TimeSpan eta) =>
        eta == TimeSpan.Zero ? "..." : eta.ToString(@"m\mss\s");

    static string TruncatePath(string path, int max) =>
        path.Length <= max ? path : "..." + path[^(max - 3)..];

    public void Dispose() {
        Scan.StateChanged -= OnStateChanged;
        FFmpegSetup.StateChanged -= OnStateChanged;
    }
}
