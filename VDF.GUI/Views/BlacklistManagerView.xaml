<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:vm="clr-namespace:VDF.GUI.ViewModels"
        xmlns:app="clr-namespace:VDF.GUI;assembly=VDF.GUI"
        x:Class="VDF.GUI.Views.BlacklistManagerView"
        x:DataType="vm:BlacklistManagerVM"
        Width="640"
        Height="480"
        MinWidth="420"
        MinHeight="320"
        Icon="/Assets/icon.ico"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.Title]}">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Opacity="0.8"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.Description]}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding GroupCountText}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <!-- Empty-state hint -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.Empty]}"
                   IsVisible="{Binding IsEmpty}"
                   Opacity="0.6"
                   FontStyle="Italic"
                   Margin="0,0,0,8" />

        <!-- Status / result message -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Opacity="0.6"
                   Margin="0,8,0,0" />

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.UnmarkSelected]}"
                    Command="{Binding UnmarkSelectedCommand}"
                    CommandParameter="{Binding ElementName=EntriesListBox, Path=SelectedItems}" />
            <Button Content="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.PruneMissing]}"
                    ToolTip.Tip="{Binding Source={x:Static app:App.Lang}, Path=[BlacklistManager.PruneMissingTooltip]}"
                    Command="{Binding PruneMissingFilesCommand}" />
            <Button Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.ClearAll]}"
                    Command="{Binding ClearAllCommand}" />
            <Button Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.Close]}"
                    MinWidth="90"
                    IsCancel="True"
                    Click="Close_Click" />
        </StackPanel>

        <!-- Entries list -->
        <Border Padding="4"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <ListBox x:Name="EntriesListBox"
                     Background="Transparent"
                     ItemsSource="{Binding Entries}"
                     SelectionMode="Multiple">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:BlacklistEntryVM">
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding PathsDisplay}"
                                       FontFamily="Consolas, Menlo, monospace"
                                       FontSize="12"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
