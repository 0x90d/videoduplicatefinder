<Window
    x:Class="VDF.GUI.Views.ExpressionBuilder"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="using:VDF.GUI.Data"
    xmlns:vm="using:VDF.GUI.ViewModels"
    x:DataType="vm:ExpressionBuilderVM"
    Title="{Binding Source={x:Static local:App.Lang}, Path=[ExpressionBuilder.Title]}"
    MinWidth="520"
    MaxWidth="680"
    d:DesignHeight="450"
    d:DesignWidth="800"
    CanResize="false"
    Icon="/Assets/icon.ico"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid
        Margin="16"
        RowDefinitions="Auto,Auto,Auto,Auto"
        RowSpacing="12">

        <!--  available properties reference  -->
        <Border
            Padding="12"
            Background="{actipro:ThemeResource Container1BackgroundBrush}"
            BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <ScrollViewer Height="280" VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock
                    FontFamily="Consolas, Menlo, monospace"
                    FontSize="12"
                    LineHeight="18"
                    Text="{Binding AvailableProperties}"
                    TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!--  expression input  -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">
            <TextBlock
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static local:App.Lang}, Path=[ExpressionBuilder.ExpressionLabel]}" />
            <AutoCompleteBox
                x:Name="ExpressionHistoryInput"
                Grid.Column="1"
                FontFamily="Consolas, Menlo, monospace"
                ItemsSource="{Binding ExpressionHistory}"
                Text="{Binding ExpressionText, Mode=TwoWay}" />
        </Grid>

        <!--  presets  -->
        <Grid
            Grid.Row="2"
            ColumnDefinitions="Auto,*,Auto,Auto"
            ColumnSpacing="8">
            <TextBlock
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static local:App.Lang}, Path=[Preset.Label]}" />
            <ComboBox
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding ExpressionPresets}"
                SelectedItem="{Binding SelectedPreset}">
                <ComboBox.DisplayMemberBinding>
                    <Binding Path="Name" DataType="data:ExpressionPreset" />
                </ComboBox.DisplayMemberBinding>
            </ComboBox>
            <Button
                Grid.Column="2"
                Command="{Binding SavePresetCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Preset.Save]}" />
            <Button
                Grid.Column="3"
                Command="{Binding DeletePresetCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Preset.Delete]}" />
        </Grid>

        <!--  footer  -->
        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                MinWidth="100"
                Classes="accent"
                Command="{Binding OKCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.OK]}"
                IsDefault="True" />
            <Button
                MinWidth="100"
                Command="{Binding CancelCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Cancel]}"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
