<UserControl
    x:Class="VDF.GUI.Views.ScanningView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:data="clr-namespace:VDF.GUI.Data;assembly=VDF.GUI"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:vm="clr-namespace:VDF.GUI.ViewModels;assembly=VDF.GUI"
    x:DataType="vm:MainWindowVM">

  <!-- Mockup .scancard: centered 780px column; counts + remaining top-right,
       elapsed + current file directly under the bar, bordered trust note.
       The log tail lives OUTSIDE the card and stretches with the window so long
       paths and remediation hints are not clipped to 780px (#836). -->
  <Grid RowDefinitions="Auto,*">
    <StackPanel
        Grid.Row="0"
        Width="780"
        MaxWidth="780"
        Margin="32,44,32,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top">

      <!-- header row -->
      <DockPanel LastChildFill="False" Margin="0,0,0,6">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="12">
          <TextBlock FontSize="19" FontWeight="SemiBold" VerticalAlignment="Center"
                     Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.Title]}" />
          <Border CornerRadius="10" Padding="10,2" VerticalAlignment="Center"
                  Background="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}"
                  IsVisible="{Binding ScanStageText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding ScanStageText}" />
          </Border>
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" FontSize="13.5" Opacity="0.8" VerticalAlignment="Center">
          <Run Text="{Binding ScanProgressCount, Mode=OneWay}" />
          <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.FilesUnit]}" />
          <Run Text="· ~" /><Run Text="{Binding RemainingTime, Mode=OneWay}" />
          <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.Left]}" />
        </TextBlock>
      </DockPanel>

      <ProgressBar
          Height="10"
          CornerRadius="5"
          Maximum="{Binding ScanProgressMaxValue, Mode=OneWay}"
          Value="{Binding ScanProgressValue, Mode=OneWay}" />

      <!-- elapsed + current file (mockup .scanmeta) -->
      <StackPanel Orientation="Horizontal" Spacing="18" Margin="0,6,0,0">
        <TextBlock FontSize="12" Opacity="0.55">
          <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.ElapsedTime]}" />
          <Run Text="{Binding TimeElapsed, Mode=OneWay}" />
        </TextBlock>
        <TextBlock FontSize="12" Opacity="0.55" MaxWidth="520"
                   FontFamily="Cascadia Mono,Consolas,monospace"
                   TextTrimming="PrefixCharacterEllipsis"
                   Text="{Binding ScanCurrentFile}" />
      </StackPanel>

      <!-- per-drive rows (mockup .drives): label + type chip | byte-weighted bar | files stat.
           Present only while the analysis phase reports drive data; compare phases carry none. -->
      <ItemsControl
          Margin="0,26,0,0"
          IsVisible="{Binding ScanDrives.HasRows}"
          ItemsSource="{Binding ScanDrives.Rows}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="data:ScanDriveRow">
            <Grid ColumnDefinitions="200,*,150">
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"
                           Text="{Binding Root}" />
                <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding HasType}">
                  <TextBlock FontSize="10.5" FontWeight="Bold" LetterSpacing="0.6" Opacity="0.55"
                             Text="{Binding TypeLabel}" />
                </Border>
              </StackPanel>
              <ProgressBar Grid.Column="1" Height="7" CornerRadius="3.5" Margin="14,0"
                           VerticalAlignment="Center"
                           Maximum="1"
                           Value="{Binding Fraction, Mode=OneWay}" />
              <TextBlock Grid.Column="2" FontSize="12" Opacity="0.8"
                         VerticalAlignment="Center" TextAlignment="Right"
                         Text="{Binding Stat}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- actions + bordered trust note -->
      <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,26,0,0">
        <Button
            FontSize="13" Padding="16,7" VerticalAlignment="Center"
            Command="{Binding PauseScanCommand}"
            IsVisible="{Binding !IsPaused}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="⏸" FontSize="12" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.Pause]}" />
          </StackPanel>
        </Button>
        <Button
            FontSize="13" Padding="16,7" VerticalAlignment="Center"
            Command="{Binding ResumeScanCommand}"
            IsVisible="{Binding IsPaused}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="▶" FontSize="12" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.Resume]}" />
          </StackPanel>
        </Button>
        <Button
            FontSize="13" Padding="16,7" VerticalAlignment="Center"
            Command="{Binding StopScanCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="⏹" FontSize="12" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.Stop]}" />
          </StackPanel>
        </Button>
        <Border CornerRadius="8" Padding="14,7"
                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                BorderThickness="1">
          <TextBlock FontSize="12.5" Opacity="0.6" VerticalAlignment="Center"
                     Text="{Binding Source={x:Static local:App.Lang}, Path=[Scan.PauseNote]}" />
        </Border>
      </StackPanel>

    </StackPanel>

    <!-- last few log lines (mockup .logtail): full window width, hover for the
         complete message (#836) -->
    <Border Grid.Row="1" Margin="32,26,32,24" Padding="0,12,0,0"
            VerticalAlignment="Top"
            BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
            BorderThickness="0,1,0,0">
      <ItemsControl ItemsSource="{Binding LogTail}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="data:LogTailRow">
            <TextBlock FontSize="11.5" Opacity="0.55" Margin="0,1.5"
                       TextTrimming="CharacterEllipsis" Text="{Binding Display}">
              <ToolTip.Tip>
                <TextBlock MaxWidth="800" TextWrapping="Wrap" Text="{Binding Tooltip}" />
              </ToolTip.Tip>
            </TextBlock>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>
  </Grid>
</UserControl>
