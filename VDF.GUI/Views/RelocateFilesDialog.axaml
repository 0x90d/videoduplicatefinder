<Window
    x:Class="VDF.GUI.RelocateFilesDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:app="clr-namespace:VDF.GUI"
    xmlns:vm="using:VDF.GUI.ViewModels"
    x:DataType="vm:RelocateFilesDialogVM"
    Title="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.Title]}"
    Width="900"
    Height="600"
    MinWidth="500"
    MinHeight="300"
    d:DesignHeight="450"
    d:DesignWidth="800"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!--  Mode selector  -->
        <StackPanel
            Margin="10,10,0,0"
            Orientation="Horizontal"
            Spacing="16">
            <RadioButton Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.ModePrefix]}" IsChecked="{Binding IsModePrefix}" />
            <RadioButton Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.ModeRescan]}" IsChecked="{Binding IsModeRescan}" />
        </StackPanel>

        <!--  Mode A  -->
        <Grid
            Grid.Row="1"
            Margin="10,12,0,8"
            IsVisible="{Binding IsModePrefix}"
            RowDefinitions="Auto,Auto">
            <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*,Auto">
                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.From]}" />
                <TextBox
                    Name="TxtOldPrefix"
                    Grid.Column="1"
                    Margin="8,0"
                    DragDrop.AllowDrop="True"
                    Text="{Binding OldPrefix}" />
                <Button
                    Grid.Column="2"
                    Command="{Binding BrowseOldPrefix}"
                    Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.FolderPicker]}" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.To]}" />
                <TextBox
                    Name="TxtNewPrefix"
                    Grid.Column="1"
                    Margin="8,0"
                    DragDrop.AllowDrop="True"
                    Text="{Binding NewPrefix}" />
                <Button
                    Grid.Column="2"
                    Command="{Binding BrowseNewPrefix}"
                    Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.FolderPicker]}" />
            </Grid>
        </Grid>

        <!--  Mode B  -->
        <Grid
            Grid.Row="1"
            Margin="10,12,0,8"
            IsVisible="{Binding IsModeRescan}"
            RowDefinitions="Auto,Auto,Auto">
            <TextBlock FontWeight="Bold" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.ScanFolders]}" />
            <Grid
                Grid.Row="1"
                Margin="0,6,0,12"
                RowDefinitions="*,Auto,Auto">
                <ListBox Name="ListScanRoots" Height="100" DragDrop.AllowDrop="True" ItemsSource="{Binding ScanRoots}" />
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button
                        Margin="8,0"
                        Command="{Binding AddScanRoot}"
                        Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.AddEllipsis]}" />
                    <Button Command="{Binding RemoveScanRoot}" Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.Remove]}" />
                </StackPanel>
            </Grid>

            <StackPanel
                Grid.Row="2"
                Orientation="Horizontal"
                Spacing="16">
                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.MultipleCandidates]}" />
                <CheckBox Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.CheckLastWriteTime]}" IsChecked="{Binding UseModifiedTime}" />
                <CheckBox Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.CheckDuration]}" IsChecked="{Binding UseDuration}" />
            </StackPanel>
        </Grid>

        <!--  Preview list: header strip + virtualized rows (shared column layout)  -->
        <Grid
            Grid.Row="2"
            Margin="10,12,0,12"
            RowDefinitions="Auto,*">
            <Border
                Padding="8,4"
                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="56,2*,2*,*,*">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.65" Text="{Binding Source={x:Static app:App.Lang}, Path=[Apply]}" />
                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Opacity="0.65" Text="{Binding Source={x:Static app:App.Lang}, Path=[Path]}" />
                    <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Opacity="0.65" Text="{Binding Source={x:Static app:App.Lang}, Path=[NewPath]}" />
                    <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Opacity="0.65" Text="{Binding Source={x:Static app:App.Lang}, Path=[Confidence]}" />
                    <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" Opacity="0.65" Text="{Binding Source={x:Static app:App.Lang}, Path=[Note]}" />
                </Grid>
            </Border>
            <ListBox
                Grid.Row="1"
                Background="Transparent"
                ItemsSource="{Binding Preview}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="8,2" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:RelocateCandidate">
                        <Grid ColumnDefinitions="56,2*,2*,*,*">
                            <CheckBox IsChecked="{Binding Selected}" />
                            <TextBlock Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding OldPath}" ToolTip.Tip="{Binding OldPath}" />
                            <TextBlock Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding NewPath}" ToolTip.Tip="{Binding NewPath}" />
                            <TextBlock Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Center" Text="{Binding ConfidenceString}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding Note}" ToolTip.Tip="{Binding Note}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,0,10,10"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.NoteNoPath]}" />
            <Button Command="{Binding CheckAllResults}" Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.CheckAll]}" />
            <Button Command="{Binding UncheckAllResults}" Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.UncheckAll]}" />
            <Button Command="{Binding BuildPreview}" Content="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.CreatePreview]}" />
            <Button
                Command="{Binding Apply}"
                Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.Apply]}"
                IsEnabled="{Binding CanApply}" />
            <Button Command="{Binding Cancel}" Content="{Binding Source={x:Static app:App.Lang}, Path=[Dialog.Cancel]}" />
        </StackPanel>

        <!--  Loading Indicator  -->
        <Border
            Grid.RowSpan="4"
            Grid.ColumnSpan="4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#80000000"
            IsVisible="{Binding IsLoading}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <TextBlock HorizontalAlignment="Center" Text="{Binding Source={x:Static app:App.Lang}, Path=[RelocateFilesDialog.EnumeratingFiles]}" />
                <ProgressBar
                    Width="300"
                    Height="12"
                    IsIndeterminate="{Binding IsLoading}"
                    Maximum="1"
                    Minimum="0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
