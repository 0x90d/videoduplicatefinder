<Window
    x:Class="VDF.GUI.Views.DatabaseViewer"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:app="clr-namespace:VDF.GUI"
    xmlns:ctl="clr-namespace:VDF.GUI.Controls;assembly=VDF.GUI"
    xmlns:vm="using:VDF.GUI.ViewModels"
    x:DataType="vm:DatabaseViewerVM"
    Title="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Title]}"
    Height="640"
    Width="1060"
    MinWidth="640"
    MinHeight="360"
    d:DesignHeight="450"
    d:DesignWidth="800"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

  <Window.Styles>
    <Style Selector="ToggleButton.chip, Button.chip">
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="TextBlock.colheader">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.65" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.mini">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="10,3" />
    </Style>
    <!-- flag chips (same 1px-border badge language as the results view) -->
    <Style Selector="Button.fchip">
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.fchip TextBlock">
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Opacity" Value="0.75" />
    </Style>
    <Style Selector="Button.fchip.warn">
      <Setter Property="Background" Value="{DynamicResource VdfWarnSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VdfWarnBorderBrush}" />
    </Style>
    <Style Selector="Button.fchip.warn TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource VdfWarnBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.fchip.err">
      <Setter Property="Background" Value="{DynamicResource VdfDangerSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VdfDangerBorderBrush}" />
    </Style>
    <Style Selector="Button.fchip.err TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource VdfDangerBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.pencil">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.pencil:pointerover">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

    <!-- ======== Toolbar: type/error/flag filter chips · search · sort ======== -->
    <Border
        Grid.Row="0"
        Padding="8,6"
        Background="{actipro:ThemeResource Container2BackgroundBrush}"
        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
        BorderThickness="0,0,0,1">
      <WrapPanel VerticalAlignment="Center">
        <ToggleButton Classes="chip" IsChecked="{Binding IsTypeAll, Mode=OneWay}"
                      Command="{Binding SetTypeFilterCommand}" CommandParameter="All"
                      Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.FilterAll]}" />
        <ToggleButton Classes="chip" Margin="4,0,0,0" IsChecked="{Binding IsTypeVideos, Mode=OneWay}"
                      Command="{Binding SetTypeFilterCommand}" CommandParameter="Videos"
                      Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.FilterVideos]}" />
        <ToggleButton Classes="chip" Margin="4,0,0,0" IsChecked="{Binding IsTypeImages, Mode=OneWay}"
                      Command="{Binding SetTypeFilterCommand}" CommandParameter="Images"
                      Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.FilterImages]}" />
        <ToggleButton Classes="chip" Margin="8,0,0,0" IsChecked="{Binding IsErrorsOnly, Mode=OneWay}"
                      Command="{Binding ToggleErrorsOnlyCommand}"
                      Content="{Binding ErrorsChipText}" />
        <Button Classes="chip" Margin="4,0,0,0">
          <Button.Content>
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.FilterFlags]}" />
              <TextBlock Text="{Binding FlagFilterLabel}" FontWeight="SemiBold"
                         IsVisible="{Binding HasFlagFilter}" />
              <TextBlock Text="▾" FontSize="10" VerticalAlignment="Center" />
            </StackPanel>
          </Button.Content>
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="ThumbnailError">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ThumbnailError]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountThumbError}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="MetadataError">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.MetadataError]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountMetadataError}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="TooDark">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.TooDark]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountTooDark}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="ManuallyExcluded">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ManuallyExcluded]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountExcluded}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="NoAudioTrack">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.NoAudioTrack]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountNoAudio}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="SilentAudioTrack">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.SilentAudioTrack]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountSilent}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter="ReparsePoint">
                <MenuItem.Header>
                  <DockPanel MinWidth="230" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ReparsePoint]}" />
                    <TextBlock DockPanel.Dock="Right" Opacity="0.55" Text="{Binding CountReparse}" />
                  </DockPanel>
                </MenuItem.Header>
              </MenuItem>
              <Separator />
              <MenuItem Command="{Binding SetFlagFilterCommand}" CommandParameter=""
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.FilterClear]}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
        <Border Width="1" Height="20" Margin="10,0" Background="{actipro:ThemeResource Container3BorderBrush}" />
        <Button Classes="chip">
          <Button.Content>
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.SortLabel]}" />
              <TextBlock Text="{Binding SortLabel}" FontWeight="SemiBold" />
              <TextBlock Text="▾" FontSize="10" VerticalAlignment="Center" />
            </StackPanel>
          </Button.Content>
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Command="{Binding SetSortCommand}" CommandParameter="Path"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.Path]}" />
              <MenuItem Command="{Binding SetSortCommand}" CommandParameter="Size"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.Size]}" />
              <MenuItem Command="{Binding SetSortCommand}" CommandParameter="Created"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.Created]}" />
              <MenuItem Command="{Binding SetSortCommand}" CommandParameter="Duration"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.Duration]}" />
              <MenuItem Command="{Binding SetSortCommand}" CommandParameter="Bitrate"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.Bitrate]}" />
              <Separator />
              <MenuItem IsEnabled="False" FontSize="11"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Sort.ByFlag]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="ManuallyExcluded"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ManuallyExcluded]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="ThumbnailError"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ThumbnailError]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="MetadataError"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.MetadataError]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="TooDark"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.TooDark]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="NoAudioTrack"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.NoAudioTrack]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="SilentAudioTrack"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.SilentAudioTrack]}" />
              <MenuItem Command="{Binding SetFlagSortCommand}" CommandParameter="ReparsePoint"
                        Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flag.ReparsePoint]}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
        <TextBox MinWidth="200" Margin="10,0,0,0" FontSize="12"
                 Text="{Binding SearchText}"
                 PlaceholderText="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Search]}" />
      </WrapPanel>
    </Border>

    <!-- ======== Column header strip (right-click: show/hide) ======== -->
    <Border
        Grid.Row="1"
        Padding="8,4"
        Background="{actipro:ThemeResource Container2BackgroundBrush}"
        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
        BorderThickness="0,0,0,1">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Size]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowSizeColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.DateCreated]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowCreatedColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Modified]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowModifiedColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Duration]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowDurationColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Resolution]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowResolutionColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Codec]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowCodecColumn}" />
          <MenuItem Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flags]}"
                    ToggleType="CheckBox" IsChecked="{Binding ShowFlagsColumn}" />
        </ContextMenu>
      </Border.ContextMenu>
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="200" Margin="8,0,0,0"
                   IsVisible="{Binding ShowFlagsColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Flags]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="130" Margin="8,0,0,0"
                   IsVisible="{Binding ShowCodecColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Codec]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="110" Margin="8,0,0,0"
                   IsVisible="{Binding ShowResolutionColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Resolution]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="70" Margin="8,0,0,0"
                   IsVisible="{Binding ShowDurationColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Duration]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="80" Margin="8,0,0,0"
                   IsVisible="{Binding ShowModifiedColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Col.Modified]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="80" Margin="8,0,0,0"
                   IsVisible="{Binding ShowCreatedColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.DateCreated]}" />
        <TextBlock DockPanel.Dock="Right" Classes="colheader" Width="78" Margin="8,0,0,0" TextAlignment="Right"
                   IsVisible="{Binding ShowSizeColumn}"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.Size]}" />
        <TextBlock Classes="colheader"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[Path]}" />
      </DockPanel>
    </Border>

    <!-- ======== Entries (virtualized) ======== -->
    <ListBox
        x:Name="dbList"
        Grid.Row="2"
        Background="Transparent"
        ItemsSource="{Binding DatabaseFilesView}"
        SelectionMode="Multiple"
        SelectionChanged="OnSelectionChanged"
        DoubleTapped="OnListDoubleTapped"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <!-- Delete key binding is applied programmatically by KeyboardShortcutManager -->
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="8,2" />
          <Setter Property="MinHeight" Value="0" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
      </ListBox.Styles>
      <ListBox.ContextMenu>
        <ContextMenu>
          <MenuItem Command="{Binding OpenSelectedInFolderCommand}"
                    Header="{Binding Source={x:Static app:App.Lang}, Path=[MainWindow.ContextMenu.OpenInFolder]}" />
          <MenuItem Command="{Binding CopySelectedPathsCommand}"
                    Header="{Binding Source={x:Static app:App.Lang}, Path=[MainWindow.ContextMenu.CopyPaths]}" />
          <Separator />
          <MenuItem Command="{Binding ToggleExcludeSelectedCommand}"
                    Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ToggleExclude]}" />
          <MenuItem Command="{Binding ClearHashesSelectedCommand}"
                    Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ClearHashes]}"
                    ToolTip.Tip="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ClearHashesTip]}" />
          <Separator />
          <MenuItem Command="{Binding DeleteSelectedEntries}"
                    Header="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.RemoveEntries]}" />
        </ContextMenu>
      </ListBox.ContextMenu>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:DatabaseEntryVM">
          <DockPanel LastChildFill="True">
            <!-- flags: chips, click = filter by that flag -->
            <ItemsControl DockPanel.Dock="Right" Width="200" Margin="8,0,0,0" VerticalAlignment="Center"
                          IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowFlagsColumn}"
                          ItemsSource="{Binding FlagChips}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DbFlagChip">
                  <Button Classes="fchip" Margin="0,1,4,1"
                          Classes.warn="{Binding Kind, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=warn}"
                          Classes.err="{Binding Kind, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=err}"
                          Command="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).FilterByChipCommand}"
                          CommandParameter="{Binding}">
                    <TextBlock Text="{Binding Label}" />
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock DockPanel.Dock="Right" Width="130" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowCodecColumn}"
                       Text="{Binding CodecText}" />
            <TextBlock DockPanel.Dock="Right" Width="110" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowResolutionColumn}"
                       Text="{Binding ResolutionText}" />
            <TextBlock DockPanel.Dock="Right" Width="70" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowDurationColumn}"
                       Text="{Binding DurationText}" />
            <TextBlock DockPanel.Dock="Right" Width="80" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowModifiedColumn}"
                       Text="{Binding DateModifiedText}" />
            <TextBlock DockPanel.Dock="Right" Width="80" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowCreatedColumn}"
                       Text="{Binding DateCreatedText}" />
            <TextBlock DockPanel.Dock="Right" Width="78" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"
                       IsVisible="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).ShowSizeColumn}"
                       Text="{Binding SizeText}" />
            <!-- file cell: name + folder; explicit edit mode via ✎ / F2 / double-click -->
            <StackPanel Margin="0,1,8,1" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="2"
                          IsVisible="{Binding !IsEditingPath}">
                <TextBlock FontSize="12.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           Text="{Binding FileName}" />
                <Button Classes="pencil" Content="✎"
                        ToolTip.Tip="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.EditPath]}"
                        Command="{Binding $parent[Window].((vm:DatabaseViewerVM)DataContext).BeginPathEditCommand}"
                        CommandParameter="{Binding}" />
              </StackPanel>
              <ctl:MiddleEllipsisTextBlock FontSize="11" Opacity="0.6"
                         IsVisible="{Binding !IsEditingPath}"
                         Text="{Binding FolderText}" />
              <!-- commit on Enter/focus-loss, Escape restores (handled in code-behind) -->
              <TextBox FontSize="12" Padding="4,2" MinHeight="0"
                       IsVisible="{Binding IsEditingPath}"
                       AttachedToVisualTree="OnPathEditorAttached"
                       KeyDown="OnPathEditorKeyDown"
                       LostFocus="OnPathEditorLostFocus"
                       Text="{Binding Path}" />
            </StackPanel>
          </DockPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- ======== Action bar (appears with a selection) ======== -->
    <Border
        Grid.Row="3"
        Padding="10,7"
        Background="{actipro:ThemeResource Container2BackgroundBrush}"
        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
        BorderThickness="0,1,0,0"
        IsVisible="{Binding !!SelectedCount}">
      <DockPanel LastChildFill="False">
        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0">
          <Run Text="{Binding SelectedCount, Mode=OneWay}" />
          <Run Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.SelectedSuffix]}" />
        </TextBlock>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="mini" Command="{Binding ToggleExcludeSelectedCommand}"
                  Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ToggleExclude]}" />
          <Button Classes="mini" Command="{Binding ClearHashesSelectedCommand}"
                  Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ClearHashes]}"
                  ToolTip.Tip="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.ClearHashesTip]}" />
          <Button Classes="mini" Command="{Binding OpenSelectedInFolderCommand}"
                  Content="{Binding Source={x:Static app:App.Lang}, Path=[MainWindow.ContextMenu.OpenInFolder]}" />
          <Button Classes="mini" Background="{DynamicResource VdfDangerBrush}" Foreground="White"
                  Command="{Binding DeleteSelectedEntries}"
                  Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.RemoveEntries]}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="12" Opacity="0.55"
                   Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.RemoveNote]}" />
      </DockPanel>
    </Border>

    <!-- ======== Statusline ======== -->
    <Border
        Grid.Row="4"
        Padding="10,4"
        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
        BorderThickness="0,1,0,0">
      <DockPanel LastChildFill="False">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock FontSize="12" Opacity="0.55">
            <Run Text="{Binding EntryCountText, Mode=OneWay}" />
            <Run Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.StatusEntries]}" />
          </TextBlock>
          <TextBlock FontSize="12" Opacity="0.55" IsVisible="{Binding IsFiltered}">
            <Run Text="{Binding ShownCountText, Mode=OneWay}" />
            <Run Text="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.StatusShown]}" />
          </TextBlock>
          <!-- Bulk cleanup of the filtered view (confirmed) -->
          <Button Classes="pencil" FontSize="12" VerticalAlignment="Center"
                  IsVisible="{Binding IsFiltered}"
                  Command="{Binding RemoveShownEntriesCommand}"
                  Content="{Binding Source={x:Static app:App.Lang}, Path=[DatabaseViewer.RemoveShown]}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Right" FontSize="12" Opacity="0.55" VerticalAlignment="Center"
                   Text="{Binding DatabaseLocationText}" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
