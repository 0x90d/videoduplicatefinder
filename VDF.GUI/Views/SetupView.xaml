<UserControl
    x:Class="VDF.GUI.Views.SetupView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Settings="clr-namespace:VDF.GUI.Data;assembly=VDF.GUI"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:mvvm="clr-namespace:VDF.GUI.Mvvm;assembly=VDF.GUI"
    xmlns:vm="clr-namespace:VDF.GUI.ViewModels;assembly=VDF.GUI"
    x:DataType="vm:MainWindowVM">

  <UserControl.Resources>
    <!-- local instances: StaticResource inside templates resolves against THIS scope -->
    <mvvm:BoolToValueConverter x:Key="ExcludedOpacityConverter" TrueValue="0.55" FalseValue="1.0" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.paneltitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style Selector="Border.foldercard">
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}" />
    </Style>
    <Style Selector="Border.profilecard">
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Border.profilecard.active">
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushEmphasizedAccent}" />
    </Style>
    <!-- mockup .folder .drive: accent-soft chip with accent label; excluded flips to danger -->
    <Style Selector="Border.drivechip">
      <Setter Property="Background" Value="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}" />
    </Style>
    <Style Selector="Border.drivechip TextBlock">
      <Setter Property="Foreground" Value="{actipro:ThemeResource ControlForegroundBrushSoftAccent}" />
    </Style>
    <Style Selector="Border.drivechip.excluded">
      <Setter Property="Background" Value="{actipro:ThemeResource ControlBackgroundBrushSoftDanger}" />
    </Style>
    <Style Selector="Border.drivechip.excluded TextBlock">
      <Setter Property="Foreground" Value="{actipro:ThemeResource ControlForegroundBrushSoftDanger}" />
    </Style>
  </UserControl.Styles>

  <!-- Mockup structure: hint strip on top, split panels (right panel tinted, left border),
       window-wide status line at the bottom. -->
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- welcome strip -->
    <Border
        Grid.Row="0"
        CornerRadius="8"
        Padding="12,8"
        Margin="24,14,24,4"
        Background="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}"
        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
        BorderThickness="1"
        IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=!WelcomeStripDismissed}">
      <DockPanel LastChildFill="True">
        <Button
            DockPanel.Dock="Right"
            Background="Transparent"
            BorderThickness="0"
            FontSize="12"
            Opacity="0.7"
            VerticalAlignment="Center"
            Command="{Binding DismissWelcomeStripCommand}"
            Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Dismiss]}" />
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock FontSize="13" FontWeight="SemiBold"
                     Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Title]}" />
          <TextBlock FontSize="13" Opacity="0.8" TextWrapping="Wrap"
                     Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Text]}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- split panels -->
    <Grid Grid.Row="1" ColumnDefinitions="1.25*,*" Margin="0,10,0,0">

      <!-- ===== left: where to look ===== -->
      <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,14,28,20">
          <TextBlock Classes="paneltitle" Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.WhereToLook]}" />
          <ItemsControl ItemsSource="{Binding SetupFolders}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SetupFolderVM">
                <Border Classes="foldercard" Opacity="{Binding IsExcluded, Converter={StaticResource ExcludedOpacityConverter}}">
                  <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="7"
                            Classes="drivechip"
                            Classes.excluded="{Binding IsExcluded}">
                      <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                 FontWeight="Bold" FontSize="12" Text="{Binding DriveLabel}" />
                    </Border>
                    <Button DockPanel.Dock="Right"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" Padding="6,2"
                            Command="{Binding $parent[UserControl].((vm:MainWindowVM)DataContext).RemoveSetupFolderCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[Setup.RemoveFolder]}">
                      <TextBlock Text="✕" FontSize="13" Opacity="0.5" />
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Classes="hyperlink"
                            FontSize="12"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowCountNow}"
                            Command="{Binding $parent[UserControl].((vm:MainWindowVM)DataContext).CountFolderNowCommand}"
                            CommandParameter="{Binding}"
                            Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.CountNow]}" />
                    <StackPanel Margin="10,0,6,0" VerticalAlignment="Center" Spacing="1">
                      <TextBlock FontSize="13.5" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"
                                 Text="{Binding Path}" ToolTip.Tip="{Binding Path}" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <ProgressBar Width="40" Height="4" IsIndeterminate="True"
                                     IsVisible="{Binding IsCounting}" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Opacity="0.7" Text="{Binding MetaText}" />
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- dashed drop zone (drop handled view-wide; Alt = exclude) -->
          <Grid Margin="0,10,0,0" MinHeight="58">
            <Rectangle
                Stroke="{actipro:ThemeResource Container4BorderBrush}"
                StrokeThickness="1.5"
                StrokeDashArray="4,3"
                RadiusX="8" RadiusY="8"
                Fill="Transparent" />
            <StackPanel Orientation="Horizontal" Spacing="4"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="14,10">
              <TextBlock FontSize="13" Opacity="0.85" FontWeight="SemiBold"
                         Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Drop.Bold]}" />
              <TextBlock FontSize="13" Opacity="0.55"
                         Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Drop.Text]}" />
              <Button Classes="hyperlink" FontSize="13" VerticalAlignment="Center"
                      Command="{Binding AddIncludesToListCommand}"
                      Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Drop.Browse]}" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button
                FontSize="12.5"
                Command="{Binding AddIncludesToListCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AddFolder]}" />
            <Button
                FontSize="12.5"
                Command="{Binding AddBlacklistToListCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AddExcluded]}" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- ===== right: what to look for (tinted panel, left border — mockup .setup-right) ===== -->
      <Border Grid.Column="1"
              Background="{actipro:ThemeResource Container2BackgroundBrush}"
              BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
              BorderThickness="1,0,0,0">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="28,14,28,20">
            <TextBlock Classes="paneltitle" Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.WhatToLookFor]}" />
            <ItemsControl ItemsSource="{Binding ScanProfileOptions}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ScanProfileOptionVM">
                  <Border Classes="profilecard"
                          Classes.active="{Binding IsActive}"
                          PointerPressed="OnProfileCardPressed">
                    <DockPanel LastChildFill="True">
                      <TextBlock DockPanel.Dock="Right" FontSize="11" Opacity="0.55"
                                 VerticalAlignment="Top" Text="{Binding TimeHint}" />
                      <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <RadioButton GroupName="ScanProfiles" IsHitTestVisible="False"
                                       IsChecked="{Binding IsActive, Mode=OneWay}" />
                          <TextBlock FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                     Text="{Binding Name}" />
                        </StackPanel>
                        <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap" Text="{Binding Description}" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,18,0,0">
              <Button
                  FontSize="14"
                  FontWeight="SemiBold"
                  Padding="26,9"
                  VerticalAlignment="Center"
                  Background="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"
                  Command="{Binding StartScanCommand}"
                  CommandParameter="FullScan">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="▶" FontSize="12" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Scan]}" />
                </StackPanel>
              </Button>
              <Button
                  Classes="hyperlink"
                  FontSize="13"
                  VerticalAlignment="Center"
                  VerticalContentAlignment="Center"
                  Click="OnAdvancedSettingsClick"
                  Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AdvancedSettings]}" />
            </StackPanel>
            <TextBlock FontSize="12" Opacity="0.55" Margin="0,12,0,0" TextWrapping="Wrap"
                       Text="{Binding SetupFootnote}" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- window-wide status line (mockup .statusline) -->
    <Border Grid.Row="2"
            Padding="24,6"
            BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
            BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" Spacing="24">
        <TextBlock FontSize="12" Opacity="0.55" Text="{Binding DatabaseInfoText}" />
        <TextBlock FontSize="12" Opacity="0.55"
                   IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=RememberDeletedContent}"
                   Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.RememberingDeletedOn]}" />
        <TextBlock FontSize="12" Opacity="0.55"
                   IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=!RememberDeletedContent}"
                   Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.RememberingDeletedOff]}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
