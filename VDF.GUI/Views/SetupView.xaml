<UserControl
    x:Class="VDF.GUI.Views.SetupView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Settings="clr-namespace:VDF.GUI.Data;assembly=VDF.GUI"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:mvvm="clr-namespace:VDF.GUI.Mvvm;assembly=VDF.GUI"
    xmlns:vm="clr-namespace:VDF.GUI.ViewModels;assembly=VDF.GUI"
    x:DataType="vm:MainWindowVM">

  <UserControl.Resources>
    <!-- local instances: StaticResource inside templates resolves against THIS scope -->
    <mvvm:BoolToValueConverter x:Key="ExcludedOpacityConverter" TrueValue="0.55" FalseValue="1.0" />
    <mvvm:BoolToValueConverter x:Key="DriveChipBackgroundConverter" TrueValue="#33BB4237" FalseValue="#2234B39C" />
    <mvvm:BoolToValueConverter x:Key="ProfileBorderConverter" TrueValue="#34B39C" FalseValue="#55808080" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.paneltitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.foldercard">
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}" />
    </Style>
    <Style Selector="Border.profilecard">
      <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="24,14,24,20" MaxWidth="1200">

      <!-- welcome strip -->
      <Border
          CornerRadius="8"
          Padding="12,8"
          Margin="0,0,0,16"
          Background="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}"
          BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
          BorderThickness="1"
          IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=!WelcomeStripDismissed}">
        <DockPanel LastChildFill="True">
          <Button
              DockPanel.Dock="Right"
              Background="Transparent"
              BorderThickness="0"
              FontSize="12"
              Opacity="0.7"
              Command="{Binding DismissWelcomeStripCommand}"
              Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Dismiss]}" />
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Title]}" />
            <TextBlock FontSize="13" Opacity="0.8" TextWrapping="Wrap"
                       Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Welcome.Text]}" />
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid ColumnDefinitions="1.25*,24,*">

        <!-- ===== left: where to look ===== -->
        <StackPanel Grid.Column="0">
          <TextBlock Classes="paneltitle" Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.WhereToLook]}" />
          <ItemsControl ItemsSource="{Binding SetupFolders}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SetupFolderVM">
                <Border Classes="foldercard" Opacity="{Binding IsExcluded, Converter={StaticResource ExcludedOpacityConverter}}">
                  <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="7"
                            Background="{Binding IsExcluded, Converter={StaticResource DriveChipBackgroundConverter}}">
                      <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                 FontWeight="Bold" FontSize="12" Text="{Binding DriveLabel}" />
                    </Border>
                    <Button DockPanel.Dock="Right"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" Padding="6,2"
                            Command="{Binding $parent[UserControl].((vm:MainWindowVM)DataContext).RemoveSetupFolderCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[Setup.RemoveFolder]}">
                      <TextBlock Text="✕" FontSize="13" Opacity="0.5" />
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Classes="hyperlink"
                            FontSize="12"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowCountNow}"
                            Command="{Binding $parent[UserControl].((vm:MainWindowVM)DataContext).CountFolderNowCommand}"
                            CommandParameter="{Binding}"
                            Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.CountNow]}" />
                    <StackPanel Margin="10,0,6,0" VerticalAlignment="Center" Spacing="1">
                      <TextBlock FontSize="13.5" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"
                                 Text="{Binding Path}" ToolTip.Tip="{Binding Path}" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <!-- tiny inline busy dot while a background walk runs -->
                        <ProgressBar Width="40" Height="4" IsIndeterminate="True"
                                     IsVisible="{Binding IsCounting}" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" Opacity="0.7" Text="{Binding MetaText}" />
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button
                FontSize="12.5"
                Command="{Binding AddIncludesToListCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AddFolder]}" />
            <Button
                FontSize="12.5"
                Command="{Binding AddBlacklistToListCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AddExcluded]}" />
          </StackPanel>
        </StackPanel>

        <!-- ===== right: what to look for ===== -->
        <StackPanel Grid.Column="2">
          <TextBlock Classes="paneltitle" Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.WhatToLookFor]}" />
          <ItemsControl ItemsSource="{Binding ScanProfileOptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ScanProfileOptionVM">
                <Border Classes="profilecard"
                        BorderBrush="{Binding IsActive, Converter={StaticResource ProfileBorderConverter}}"
                        PointerPressed="OnProfileCardPressed">
                  <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right" FontSize="11" Opacity="0.55"
                               VerticalAlignment="Top" Text="{Binding TimeHint}" />
                    <StackPanel Spacing="2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton GroupName="ScanProfiles" IsHitTestVisible="False"
                                     IsChecked="{Binding IsActive, Mode=OneWay}" />
                        <TextBlock FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Text="{Binding Name}" />
                      </StackPanel>
                      <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap" Text="{Binding Description}" />
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,18,0,0">
            <Button
                FontSize="14"
                FontWeight="SemiBold"
                Padding="26,9"
                Background="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"
                Command="{Binding StartScanCommand}"
                CommandParameter="FullScan">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="▶" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[Setup.Scan]}" />
              </StackPanel>
            </Button>
            <Button
                Classes="hyperlink"
                FontSize="13"
                Click="OnAdvancedSettingsClick"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Setup.AdvancedSettings]}" />
          </StackPanel>
          <TextBlock FontSize="12" Opacity="0.55" Margin="0,12,0,0" TextWrapping="Wrap"
                     Text="{Binding SetupFootnote}" />
          <TextBlock FontSize="12" Opacity="0.55" Margin="0,4,0,0"
                     Text="{Binding DatabaseInfoText}" />
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
