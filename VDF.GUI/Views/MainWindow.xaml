<Window
    x:Class="VDF.GUI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Settings="clr-namespace:VDF.GUI.Data;assembly=VDF.GUI"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
    xmlns:ic="clr-namespace:Avalonia.Xaml.Interactions.Custom;assembly=Xaml.Behaviors.Interactions.Custom"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="clr-namespace:Avalonia.Media;assembly=Avalonia.Base"
    xmlns:mvvm="clr-namespace:VDF.GUI.Mvvm;assembly=VDF.GUI"
    xmlns:presenters="clr-namespace:Avalonia.Controls.Presenters;assembly=Avalonia.Controls"
    xmlns:utils="clr-namespace:VDF.GUI.Utils;assembly=VDF.GUI"
    xmlns:views="clr-namespace:VDF.GUI.Views;assembly=VDF.GUI"
    xmlns:vm="clr-namespace:VDF.GUI.ViewModels;assembly=VDF.GUI"
    x:DataType="vm:MainWindowVM"
    x:Name="MainWindow"
    Width="1020"
    Height="950"
    MinWidth="750"
    MinHeight="450"
    d:DesignHeight="750"
    d:DesignWidth="900"
    BorderBrush="{actipro:ThemeResource ButtonForegroundBrush}"
    BorderThickness="1"
    ExtendClientAreaToDecorationsHint="True"
    FontSize="14"
    Icon="/Assets/icon.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Title>
        <!-- Localized app title plus the build identity (e.g. "… 4.0.0 (a225a45)").
             Releases roll to one tag, so the commit is the meaningful version. -->
        <MultiBinding StringFormat="{}{0}  —  {1}">
            <Binding Path="[App.Title]" Source="{x:Static local:App.Lang}" />
            <Binding Source="{x:Static utils:VersionInfo.ShortDisplay}" />
        </MultiBinding>
    </Window.Title>
    <Window.Resources>
        <mvvm:ExtraShortDateTimeConverter x:Key="ExtraShortDateTimeConverter" />
        <mvvm:SimilarityToFormattedConverter x:Key="SimilarityToFormattedConverter" />
        <mvvm:MetricDisplayConverter x:Key="MetricDisplayConverter" />
        <mvvm:ShowSkeletonConverter x:Key="ShowSkeletonConverter" />
    </Window.Resources>
    <Window.Styles>
        <!-- Avalonia 12 draws managed caption buttons when the client area is extended
             (ExtendClientAreaChromeHints/PreferSystemChrome no longer exists). Its button
             set includes a full-screen toggle Windows chrome never had. Hiding it via
             Button#PART_FullScreenButton works but leaves the remaining buttons offset
             from the window edge, which looks worse — so the button stays for now. -->
        <Style Selector="Button.hyperlink">
            <Setter Property="Template">
                <ControlTemplate>
                    <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline">
                        <TextBlock.Styles>
                            <Style Selector="TextBlock:pointerover">
                                <Setter Property="Foreground" Value="{actipro:ThemeResource ControlBackgroundBrushEmphasizedAccent}" />
                            </Style>
                        </TextBlock.Styles>
                    </TextBlock>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <!-- titlebar nav links (mockup .navlink: quiet text, accent-soft pill on hover) -->
        <Style Selector="Button.navlink">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Button.navlink:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}" />
        </Style>
        <Style Selector="Button.navlink:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Window.Styles>
    <Border BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderThickness="2">
        <Grid>
            <controls:ExperimentalAcrylicBorder
                x:Name="ExperimentalAcrylicBorderBackgroundWhite"
                IsHitTestVisible="False"
                IsVisible="False">
                <controls:ExperimentalAcrylicBorder.Material>
                    <media:ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="White" />
                </controls:ExperimentalAcrylicBorder.Material>
            </controls:ExperimentalAcrylicBorder>
            <controls:ExperimentalAcrylicBorder
                x:Name="ExperimentalAcrylicBorderBackgroundBlack"
                IsHitTestVisible="False"
                IsVisible="False">
                <controls:ExperimentalAcrylicBorder.Material>
                    <media:ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="Black" />
                </controls:ExperimentalAcrylicBorder.Material>
            </controls:ExperimentalAcrylicBorder>
            <TextBlock
                x:Name="TextBlockWindowTitle"
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                IsHitTestVisible="false"
                Text="{Binding #MainWindow.Title}" />
            <!-- Titlebar nav links (mockup .navlink): right-aligned before the caption
                 buttons; contextual per shell view. The strip only holds the buttons, so
                 the rest of the titlebar stays a drag region. -->
            <StackPanel
                x:Name="TitlebarNav"
                Height="30"
                Margin="0,0,190,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Orientation="Horizontal"
                Spacing="2">
                <Button
                    Classes="navlink"
                    Command="{Binding StartScanCommand}"
                    CommandParameter="FullScan"
                    Content="{Binding Source={x:Static local:App.Lang}, Path=[Shell.NewScan]}"
                    IsVisible="{Binding ShowNavNewScan}" />
                <Button
                    Classes="navlink"
                    Command="{Binding ShowShellViewCommand}"
                    CommandParameter="Main"
                    Content="{Binding Source={x:Static local:App.Lang}, Path=[Shell.BackToResults]}"
                    IsVisible="{Binding ShowNavBackToResults}" />
                <Button
                    Classes="navlink"
                    Command="{Binding ShowShellViewCommand}"
                    CommandParameter="Log"
                    Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Log]}"
                    IsVisible="{Binding ShowNavLog}" />
                <Button
                    Classes="navlink"
                    Command="{Binding ShowShellViewCommand}"
                    CommandParameter="Settings"
                    Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Settings]}"
                    IsVisible="{Binding ShowNavSettings}" />
            </StackPanel>
            <Grid x:Name="MainContentGrid" Margin="2,30,2,2">
                <Grid IsVisible="{Binding IsShellMainVisible}">
                        <Grid Margin="0,0,0,10" RowDefinitions="Auto, *, Auto">
                            <Menu Grid.Row="0" MinHeight="30"
                                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}">
                                <Menu.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </Menu.ItemsPanel>
                                <MenuItem
                                    Command="{Binding StartScanCommand}"
                                    CommandParameter="FullScan"
                                    IsVisible="{Binding !IsScanning}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="Green" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Command.Scan]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem
                                    Command="{Binding StartScanCommand}"
                                    CommandParameter="CompareOnly"
                                    IsEnabled="{Binding IsReadyToCompare}"
                                    IsVisible="{Binding !IsScanning}"
                                    ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tooltip.Rescan]}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="m19.3809,4.64738l-1.69658,1.69658c-3.12529,-3.12529 -8.21505,-3.12529 -11.34034,0c-3.12529,3.12529 -3.12529,8.21505 0,11.34034c1.518,1.60729 3.57176,2.41094 5.62553,2.41094s4.10753,-0.80365 5.71483,-2.32165c0.71435,-0.71435 0.71435,-1.78588 0,-2.50024s-1.78588,-0.71435 -2.50024,0c-1.69658,1.78588 -4.554,1.69658 -6.33988,0c-0.89294,-0.89294 -1.33941,-2.05376 -1.33941,-3.21459s0.44647,-2.32165 1.33941,-3.12529c1.69658,-1.78588 4.554,-1.78588 6.33988,0l-1.60729,1.60729c-0.53577,0.53577 -0.17859,1.518 0.62505,1.518l5.80411,0c0.53577,0 0.89294,-0.35717 0.89294,-0.89294l0,-5.89341c0,-0.80365 -0.98224,-1.16083 -1.518,-0.62505l-0.00001,0.00001l0.00001,-0.00001z" Fill="Orange" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Command.Rescan]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ResumeScanCommand}" IsVisible="{Binding IsScanning}">
