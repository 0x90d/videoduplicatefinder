                                                        Command="{Binding OpenGroupCommand}"
                                                        CommandParameter="0"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.OpenGroup]}"
                                                        IsVisible="{Binding IsMultiOpenSupported}" />
                                                    <MenuItem
                                                        Command="{Binding OpenGroupCommand}"
                                                        CommandParameter="1"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.OpenGroupInFolder]}"
                                                        IsVisible="{Binding IsMultiOpenInFolderSupported}" />
                                                    <MenuItem Command="{Binding LoadThumbnailsForGroupCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.LoadThumbnailsForGroup]}" />
                                                    <MenuItem
                                                        Command="{Binding ShowGroupInThumbnailComparerCommand}"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CompareFullsizeThumbnails]}"
                                                        InputGesture="{Binding Source={x:Static Settings:KeyboardShortcutManager.Instance}, Path=[ShowGroupInThumbnailComparer]}" />
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                    </DataGrid>
                                    <Border
                                        x:Name="EmptyOverlay"
                                        Background="Transparent"
                                        IsVisible="{Binding !Duplicates.Count}">
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="18"
                                                IsVisible="{Binding !IsScanning}"
                                                Opacity="0.9"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.EmptyState.Title]}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding !IsScanning}"
                                                Opacity="0.65"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.EmptyState.Subtitle]}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                            <WrapPanel Grid.Row="2" Margin="0,2,0,0">
                                <!-- Statistics -->
                                <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding !!Duplicates.Count}" VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.CheckedDuplicates]}" />
                                        <Run Text="{Binding DuplicatesCheckedCounter, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.Duplicates]}" />
                                        <Run Text="{Binding TotalDuplicates, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateGroups]}" />
                                        <Run Text="{Binding TotalDuplicateGroups, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateSize]}" />
                                        <Run Text="{Binding TotalDuplicatesSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.SizeRemoved]}" />
                                        <Run Text="{Binding TotalSizeRemoved, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <!-- Progress info -->
                                <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <!-- Thumbnail progress (conditional) -->
                                    <StackPanel Orientation="Horizontal" IsVisible="{Binding ShowThumbnailRetrievalProgress}" Margin="0,0,8,0">
                                        <ProgressBar MinWidth="60" Height="12" IsIndeterminate="{Binding ShowThumbnailRetrievalProgressBar}" />
                                        <TextBlock FontSize="12" Margin="4,0" Text="{Binding ThumbnailRetrievalProgressText}" />
                                        <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    </StackPanel>
                                    <!-- Scan progress -->
                                    <ProgressBar Name="PbScanProgress" MinWidth="80" Height="12"
                                        Maximum="{Binding ScanProgressMaxValue, Mode=OneWay}"
                                        Value="{Binding ScanProgressValue, Mode=OneWay}" />
                                    <TextBlock FontSize="12" Margin="4,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.ElapsedTime]}" />
                                        <Run Text="{Binding TimeElapsed, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.RemainingTime]}" />
                                        <Run Text="{Binding RemainingTime, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0" Text="{Binding ScanProgressText, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" MaxWidth="300" />
                                </StackPanel>
                            </WrapPanel>
                            <Grid
                                x:Name="BusyIndicator"
                                Grid.RowSpan="3"
                                IsVisible="{Binding IsBusy}"
                                Opacity="0.8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar
                                        Height="10"
                                        MaxWidth="200"
                                        BorderBrush="LimeGreen"
                                        BorderThickness="1"
                                        IsIndeterminate="{Binding IsBusy}" />
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="ExtraBold"
                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Busy.PleaseWait]}" />
                                    <TextBlock
                                        Name="LblBusyIndicator"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Text="{Binding IsBusyOverlayText}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Name="TabItemSettings">
                        <TabItem.Header>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Settings]}" />
                        </TabItem.Header>
                        <Grid Margin="0,0,0,10" RowDefinitions="Auto, *">
                            <Menu 
                                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}" Grid.Row="0" MinHeight="30">
                                <MenuItem Command="{Binding SaveSettingsCommand}" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.SaveTooltip]}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm2 16H5V5h11.17L19 7.83V19zm-7-7c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3zM6 6h9v4H6z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Save]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding SaveSettingsProfileCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="16" Height="16">
                                                    <Path Data="M11.04 1.33L12.71 3l.29.71v.33h-.5l-.5.5v-.83l-1.67-1.67H10v4H4v-4H2v10h3l-.5 1H2l-1-1v-10l1-1h8.33l.71.29zM7 5h2V2H7v3zm6.5 0L15 6.5l-.02.69-5.5 5.5-.13.12-.37.37-.1.09-3 1.5-.67-.67 1.5-3 .09-.1.37-.37.12-.13 5.5-5.5h.71zm-6.22 7.24l-.52 1 1.04-.48-.52-.52zm.69-1.03l.79.79 5.15-5.15-.79-.79-5.15 5.15z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.SaveToFile]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding LoadSettingsProfileCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="16" Height="16">
                                                    <Path Data="M1.5 14h11l.48-.37 2.63-7-.48-.63H14V3.5l-.5-.5H7.71l-.86-.85L6.5 2h-5l-.5.5v11l.5.5zM2 3h4.29l.86.85.35.15H13v2H8.5l-.35.15-.86.85H3.5l-.47.34-1 3.08L2 3zm10.13 10H2.19l1.67-5H7.5l.35-.15.86-.85h5.79l-2.37 6z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.LoadFromFile]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </Menu>
                            <TabControl Grid.Row="1" TabStripPlacement="Left"
                                      IsEnabled="{Binding !IsScanning}">
                                <TabControl.Styles>
                                    <Style Selector="TabItem">
                                        <Setter Property="MinWidth" Value="160" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Padding" Value="14,10" />
                                    </Style>
                                </TabControl.Styles>

                                <!-- ═══════════════ SCANNING ═══════════════ -->
                                <TabItem>
                                    <TabItem.Header>
                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.Scanning]}" />
                                    </TabItem.Header>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="16,12,16,16" Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Foreground="{actipro:ThemeResource ControlBackgroundBrushSolidWarning}"
                                                           Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MiscWikiHint]}" />
                                                <Button Classes="hyperlink" Command="{Binding OpenWikiLinkCommand}"
                                                        Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MiscWikiHyperlink]}" />
                                            </StackPanel>

                                            <!-- Comparison Parameters -->
                                            <Border Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.Percent]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left" FormatString="\{0\}%"
                                                                   Increment="0.1" Maximum="100" Minimum="1"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PercentTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=Percent}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifference]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left" FormatString="\{0\}%"
                                                                   Increment="0.1" Maximum="100" Minimum="0"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifferenceTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=PercentDurationDifference}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifferenceMinSeconds]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left"
                                                                   Increment="1" Maximum="3600" Minimum="0"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifferenceMinSecondsTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=DurationDifferenceMinSeconds}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifferenceMaxSeconds]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left"
                                                                   Increment="1" Maximum="86400" Minimum="0"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.DurationDifferenceMaxSecondsTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=DurationDifferenceMaxSeconds}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MaxSamplingDurationSeconds]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left"
                                                                   Increment="1" Maximum="86400" Minimum="0"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MaxSamplingDurationSecondsTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=MaxSamplingDurationSeconds}" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.Thumbnails]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left"
                                                                   Maximum="100" Minimum="1"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ThumbnailsTooltip]}"
                                                                   ValueChanged="Thumbnails_ValueChanged"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=Thumbnails}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MaxDegreeOfParallelism]}" />
                                                    <NumericUpDown Width="200" HorizontalAlignment="Left"
                                                                   Maximum="100" Minimum="-1"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.MaxDegreeOfParallelismTooltip]}"
                                                                   Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=MaxDegreeOfParallelism}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.OnlySameFolderDuplicates]}"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.OnlySameFolderDuplicatesTooltip]}" />
                                                        <ComboBox VerticalAlignment="Center"
                                                                  ItemsSource="{Binding FolderMatchModes}"
                                                                  SelectedItem="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=FolderMatchMode}"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.OnlySameFolderDuplicatesTooltip]}" />
                                                        <NumericUpDown Width="70" VerticalAlignment="Center" Increment="1" Maximum="20" Minimum="1"
                                                                       IsEnabled="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IsFolderMatchModeActive}"
                                                                       Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=SameFolderDepth}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Options (2-column checkboxes) -->
                                            <Border Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12">
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IncludeSubDirectories]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IncludeSubDirectories}" IsThreeState="False" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IncludeImages]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IncludeImages}" IsThreeState="False" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.UsePHashing]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=UsePHash}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.UsePHashingTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.CompareHorizontallyFlipped]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=CompareHorizontallyFlipped}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.CompareHorizontallyFlippedTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IgnoreBlackPixels]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IgnoreBlackPixels}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IgnoreBlackPixelsTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IgnoreWhitePixels]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IgnoreWhitePixels}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IgnoreWhitePixelsTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.UseExifCreationDate]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=UseExifCreationDate}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.UseExifCreationDateTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.GeneratePreviewImages]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=GeneratePreviewThumbnails}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.GeneratePreviewImagesTooltip]}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.AlwaysRetryFailedSampling]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=AlwaysRetryFailedSampling}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.AlwaysRetryFailedSamplingTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ScanAgainstEntireDatabase]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ScanAgainstEntireDatabase}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ScanAgainstEntireDatabaseTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ScanAgainstNonExistingFiles]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IncludeNonExistingFiles}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ScanAgainstNonExistingFilesTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.IgnoreReadOnlyFolders]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IgnoreReadOnlyFolders}" IsThreeState="False" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ExcludeReparsePoints]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=IgnoreReparsePoints}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ExcludeReparsePointsTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ExcludeHardLinks]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ExcludeHardLinks}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ExcludeHardLinksTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.AutoBackupScanResults]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=BackupAfterListChanged}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.AutoBackupScanResultsTooltip]}" />
                                                        <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.SaveResultsOnExit]}"
                                                                  IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=AskToSaveResultsOnExit}" IsThreeState="False"
                                                                  ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.SaveResultsOnExitTooltip]}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <!-- Partial Clip Detection -->
                                            <Border Margin="0,8,0,0"
                                                    Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontWeight="Bold"
                                                               Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipDetection]}" />
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.EnablePartialClipDetection]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=EnablePartialClipDetection}"
                                                              IsThreeState="False"
                                                              ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.EnablePartialClipDetectionTooltip]}" />
                                                    <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipDetectionWarning]}"
                                                               Foreground="{actipro:ThemeResource ControlForegroundBrushSoftWarning}"
                                                               FontSize="11" TextWrapping="Wrap"
                                                               IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=EnablePartialClipDetection}" />
                                                    <Grid ColumnDefinitions="Auto,8,80,16,Auto,8,80"
                                                          IsEnabled="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=EnablePartialClipDetection}">
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipMinRatio]}"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipMinRatioTooltip]}" />
                                                        <NumericUpDown Grid.Column="2"
                                                                       Width="80" Increment="1" Minimum="1" Maximum="94"
                                                                       Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=PartialClipMinRatioPercent}"
                                                                       ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipMinRatioTooltip]}" />
                                                        <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipSimilarityThreshold]}"
                                                                   ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipSimilarityThresholdTooltip]}" />
                                                        <NumericUpDown Grid.Column="6"
                                                                       Width="80" Increment="1" Minimum="1" Maximum="100"
                                                                       Value="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=PartialClipSimilarityThresholdPercent}"
                                                                       ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.PartialClipSimilarityThresholdTooltip]}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- ═══════════════ DIRECTORIES ═══════════════ -->
                                <TabItem>
                                    <TabItem.Header>
                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.Directories]}" />
                                    </TabItem.Header>
                                    <Grid Margin="12,12,12,10" ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,0,0,4"
                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.SearchDirectories]}" />
                                        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*,Auto">
                                            <Menu Grid.Row="0" MinHeight="30">
                                                <MenuItem Command="{Binding AddIncludesToListCommand}">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
