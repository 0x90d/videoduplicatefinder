                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Command="{Binding ExportScanResultsToCsvCommand}">
                                        <MenuItem.Header>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Menu.ExportScanResults.Csv]}" />
                                        </MenuItem.Header>
                                    </MenuItem>
                                </MenuItem>
                                <MenuItem IsVisible="{Binding !!Duplicates.Count}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Path
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                Data="M14,9 C14.5523,9 15,9.44772 15,10 L15,13 C15,14.1046 14.1046,15 13,15 L3,15 C1.89543,15 1,14.1046 1,13 L1,10 C1,9.44772 1.44772,9 2,9 C2.55228,9 3,9.44771 3,10 L3,13 L13,13 L13,10 C13,9.44771 13.4477,9 14,9 Z M8,1 C8.55228,1 9,1.44772 9,2 L9,6.58579 L10.2929,5.29289 C10.6834,4.90237 11.3166,4.90237 11.7071,5.29289 C12.0976,5.68342 12.0976,6.31658 11.7071,6.70711 L8,10.4142 L4.29289,6.70711 C3.90237,6.31658 3.90237,5.68342 4.29289,5.29289 C4.68342,4.90237 5.31658,4.90237 5.70711,5.29289 L7,6.58579 L7,2 C7,1.44772 7.44772,1 8,1 Z"
                                                Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Menu.ImportScanResults]}" />
                                            <Path
                                                Margin="4,2,0,0"
                                                VerticalAlignment="Center"
                                                Data="M 0 0 L 6 6 L 12 0 Z"
                                                Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                    <MenuItem Command="{Binding ImportScanResultsFromFileCommand}">
                                        <MenuItem.Header>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Menu.ImportScanResults.WithThumbnails]}" />
                                        </MenuItem.Header>
                                    </MenuItem>
                                </MenuItem>
                                <MenuItem Header="|" IsHitTestVisible="False" />
                                <MenuItem>
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="16" Height="16">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M2,4C2,2.89 2.9,2 4,2H7V4H4V7H2V4M22,4V7H20V4H17V2H20A2,2 0 0,1 22,4M20,20V17H22V20C22,21.11 21.1,22 20,22H17V20H20M2,20V17H4V20H7V22H4A2,2 0 0,1 2,20M10,2H14V4H10V2M10,20H14V22H10V20M20,10H22V14H20V10M2,10H4V14H2V10Z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Menu.Selection]}" />
                                            <Path
                                                Margin="4,2,0,0"
                                                VerticalAlignment="Center"
                                                Data="M 0 0 L 6 6 L 12 0 Z"
                                                Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                        <MenuItem Command="{Binding CheckWhenIdenticalCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckIdenticalKeepFirst]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CheckWhenIdenticalButSizeCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckIdenticalExceptSizeKeepSmallest]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CheckLowestQualityCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckLowestQuality]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CheckMissingFilesCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckMissingFiles]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.DateMenu]}">
                                            <MenuItem Command="{Binding CheckOldestCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckOldest]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding CheckNewestCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckNewest]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem>
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckCustom]}" />
                                            </MenuItem.Header>
                                            <MenuItem Command="{Binding CheckCustomCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ExpressionBuilder]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding OpenCustomSelectionCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CustomSelection]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem Command="{Binding ClearCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ClearCheckedItems]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding InvertCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.InvertCheckedItems]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding ExportCheckedItemsCleanupDryRunReportCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ExportCheckedItemsCleanupDryRun]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </MenuItem>
                            </Menu>
                            <Grid Grid.Row="1">
                                <!-- One window, three states: Setup → Scanning → Review (stage 2) -->
                                <views:SetupView IsVisible="{Binding IsSetupState}" />
                                <views:ScanningView IsVisible="{Binding IsScanningState}" />
                                <views:DuplicateResultsView
                                    x:Name="NewResultsView"
                                    IsVisible="{Binding IsReviewState}" />
                            </Grid>
                            <WrapPanel Grid.Row="2" Margin="0,2,0,0">
                                <!-- Statistics -->
                                <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding !!Duplicates.Count}" VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.CheckedDuplicates]}" />
                                        <Run Text="{Binding DuplicatesCheckedCounter, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.CheckedSize]}" />
                                        <Run Text="{Binding DuplicatesCheckedSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.Duplicates]}" />
                                        <Run Text="{Binding TotalDuplicates, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateGroups]}" />
                                        <Run Text="{Binding TotalDuplicateGroups, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateSize]}" />
                                        <Run Text="{Binding TotalDuplicatesSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.PotentialSavingsTooltip]}">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.PotentialSavings]}" />
                                        <Run Text="{Binding PotentialSavings, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.SizeRemoved]}" />
                                        <Run Text="{Binding TotalSizeRemoved, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <!-- Progress info -->
                                <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <!-- Thumbnail progress: determinate once the engine reports counts (#791);
                                         indeterminate only in the startup moment before the first event. -->
                                    <StackPanel Orientation="Horizontal" IsVisible="{Binding ShowThumbnailRetrievalProgress}" Margin="0,0,8,0">
                                        <ProgressBar MinWidth="60" Height="12"
                                            IsIndeterminate="{Binding !ThumbnailProgressMax}"
                                            Maximum="{Binding ThumbnailProgressMax, Mode=OneWay}"
                                            Value="{Binding ThumbnailProgressCurrent, Mode=OneWay}" />
                                        <TextBlock FontSize="12" Margin="4,0" Text="{Binding ThumbnailRetrievalProgressText}" />
                                        <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    </StackPanel>
                                    <!-- Scan progress -->
                                    <ProgressBar Name="PbScanProgress" MinWidth="80" Height="12"
                                        Maximum="{Binding ScanProgressMaxValue, Mode=OneWay}"
                                        Value="{Binding ScanProgressValue, Mode=OneWay}" />
                                    <TextBlock FontSize="12" Margin="6,0,2,0" VerticalAlignment="Center"
                                        IsVisible="{Binding IsScanning}"
                                        Text="{Binding ScanProgressCount, Mode=OneWay}" />
                                    <TextBlock FontSize="12" Margin="4,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.ElapsedTime]}" />
                                        <Run Text="{Binding TimeElapsed, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.RemainingTime]}" />
                                        <Run Text="{Binding RemainingTime, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0" Text="{Binding ScanProgressText, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" MaxWidth="500" />
                                </StackPanel>
                            </WrapPanel>
                            <Grid
                                x:Name="BusyIndicator"
                                Grid.RowSpan="3"
                                Opacity="0.8">
                                <!-- Scans render in the window center (Scanning state) — the busy
                                     curtain only covers non-scan operations (delete, import, …). -->
                                <Grid.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="IsBusy" />
                                        <Binding Path="!IsScanning" />
                                    </MultiBinding>
                                </Grid.IsVisible>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar
                                        Height="10"
                                        MaxWidth="200"
                                        BorderBrush="LimeGreen"
                                        BorderThickness="1"
                                        IsIndeterminate="{Binding IsBusy}" />
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="ExtraBold"
                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Busy.PleaseWait]}" />
                                    <TextBlock
                                        Name="LblBusyIndicator"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Text="{Binding IsBusyOverlayText}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                </Grid>
                <views:SettingsView IsVisible="{Binding IsShellSettingsVisible}" />
                <views:LogView IsVisible="{Binding IsShellLogVisible}" />
            </Grid>
        </Grid>
    </Border>


</Window>
