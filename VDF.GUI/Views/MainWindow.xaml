                                                </StackPanel>
                                            </Border>
                                            <!-- Column visibility -->
                                            <Border Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12">
                                                <StackPanel Spacing="4">
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ShowPathColumn]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowPathColumn}" IsThreeState="False" />
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ShowDurationColumn]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowDurationColumn}" IsThreeState="False" />
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ShowFormatColumn]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowFormatColumn}" IsThreeState="False" />
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ShowAudioColumn]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowAudioColumn}" IsThreeState="False" />
                                                    <CheckBox Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.ShowSimilarityColumn]}"
                                                              IsChecked="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowSimilarityColumn}" IsThreeState="False" />
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Margin="0,2,0,4" Foreground="{actipro:ThemeResource ControlBackgroundBrushSolidWarning}"
                                                       Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.RestartHint]}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- ═══════════════ SHORTCUTS ═══════════════ -->
                                <TabItem x:Name="TabItemSettingsKeyboardShortcuts">
                                    <TabItem.Header>
                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                   Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.KeyboardShortcuts]}" />
                                    </TabItem.Header>
                                    <Grid RowDefinitions="Auto,Auto,*" Margin="10">
                                        <Button Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Left"
                                                Command="{Binding ResetAllShortcutsCommand}"
                                                Content="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.KeyboardShortcuts.ResetAll]}" />
                                        <Grid Grid.Row="1" ColumnDefinitions="250,200,*" Margin="0,0,0,4">
                                            <TextBlock Grid.Column="0" FontWeight="Bold"
                                                       Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.KeyboardShortcuts.Action]}" />
                                            <TextBlock Grid.Column="1" FontWeight="Bold"
                                                       Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Settings.KeyboardShortcuts.Shortcut]}" />
                                        </Grid>
                                        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding ShortcutBindings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="250,200,*" Margin="0,2">
                                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding DisplayName}" />
                                                            <views:HotKeyBox Grid.Column="1" Margin="0,0,8,0"
                                                                             GestureText="{Binding CurrentGesture, Mode=TwoWay}" />
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                                                <Button Command="{Binding ResetCommand}" Content="&#x21BA;" ToolTip.Tip="Reset to Default"
                                                                        Padding="6,2" IsVisible="{Binding IsModified}" />
                                                                <Button Command="{Binding ClearCommand}" Content="&#x2715;" ToolTip.Tip="Clear" Padding="6,2" />
                                                                <TextBlock VerticalAlignment="Center" Foreground="Orange"
                                                                           Text="{Binding ConflictText}"
                                                                           IsVisible="{Binding ConflictText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                    <TabItem Name="TabItemLog">
                        <TabItem.Header>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Log]}" />
                        </TabItem.Header>
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Menu Grid.Row="0" MinHeight="30">
                                <MenuItem Command="{Binding ClearLogCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="1024" Height="1024">
                                                    <Path Data="M899.1 869.6l-53-305.6H864c14.4 0 26-11.6 26-26V346c0-14.4-11.6-26-26-26H618V138c0-14.4-11.6-26-26-26H432c-14.4 0-26 11.6-26 26v182H160c-14.4 0-26 11.6-26 26v192c0 14.4 11.6 26 26 26h17.9l-53 305.6c-0.3 1.5-0.4 3-0.4 4.4 0 14.4 11.6 26 26 26h723c1.5 0 3-0.1 4.4-0.4 14.2-2.4 23.7-15.9 21.2-30zM204 390h272V182h72v208h272v104H204V390z m468 440V674c0-4.4-3.6-8-8-8h-48c-4.4 0-8 3.6-8 8v156H416V674c0-4.4-3.6-8-8-8h-48c-4.4 0-8 3.6-8 8v156H202.8l45.1-260H776l45.1 260H672z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Clear]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding SaveLogCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="16" Height="16">
                                                    <Path Data="M11.04 1.33L12.71 3l.29.71v.33h-.5l-.5.5v-.83l-1.67-1.67H10v4H4v-4H2v10h3l-.5 1H2l-1-1v-10l1-1h8.33l.71.29zM7 5h2V2H7v3zm6.5 0L15 6.5l-.02.69-5.5 5.5-.13.12-.37.37-.1.09-3 1.5-.67-.67 1.5-3 .09-.1.37-.37.12-.13 5.5-5.5h.71zm-6.22 7.24l-.52 1 1.04-.48-.52-.52zm.69-1.03l.79.79 5.15-5.15-.79-.79-5.15 5.15z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.SaveToFile]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding CopyLogSelectionCommand}"
                                          CommandParameter="{Binding #LogListBox.SelectedItems}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="20" Height="20">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.CopySelected]}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </Menu>
                            <ListBox
                                x:Name="LogListBox"
                                Grid.Row="1"
                                MinHeight="70"
                                Margin="5"
                                ItemsSource="{Binding LogItems}"
                                SelectionMode="Multiple"
                                ScrollViewer.HorizontalScrollBarVisibility="Visible" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>


</Window>
