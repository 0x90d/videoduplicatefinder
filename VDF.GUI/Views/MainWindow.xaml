                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Menu.ExportScanResults.JsonPretty]}" />
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Command="{Binding ExportScanResultsToFileCommand}">
                                        <MenuItem.Header>
                                            <TextBlock
