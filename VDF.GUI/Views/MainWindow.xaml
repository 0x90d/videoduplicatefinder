                                        <MenuItem Command="{Binding CheckWhenIdenticalButSizeCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckIdenticalExceptSizeKeepSmallest]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CheckLowestQualityCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckLowestQuality]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CheckMissingFilesCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckMissingFiles]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.DateMenu]}">
                                            <MenuItem Command="{Binding CheckOldestCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckOldest]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding CheckNewestCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckNewest]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem>
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CheckCustom]}" />
                                            </MenuItem.Header>
                                            <MenuItem Command="{Binding CheckCustomCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ExpressionBuilder]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding OpenCustomSelectionCommand}">
                                                <MenuItem.Header>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CustomSelection]}" />
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem Command="{Binding ClearCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ClearCheckedItems]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding InvertCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.InvertCheckedItems]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding ExportCheckedItemsCleanupDryRunReportCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.ExportCheckedItemsCleanupDryRun]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem>
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.DeleteCheckedItems]}" />
                                                <Path
                                                    Margin="4,2,0,0"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 6 6 L 12 0 Z"
                                                    Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                        <MenuItem Command="{Binding DeleteCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.DeleteCheckedItemsFromDisk]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding DeleteCheckedItemsPermanentlyCommand}" IsVisible="{Binding IsWindows}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.DeleteCheckedItemsPermanently]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="-" />

                                        <MenuItem Command="{Binding RemoveCheckedItemsFromListCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.RemoveCheckedItemsFromList]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding CopyCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.CopyCheckedItemsToFolder]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding MoveCheckedItemsCommand}">
                                            <MenuItem.Header>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Selection.MoveCheckedItemsToFolder]}" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="|" />
                                    <CheckBox Margin="5,0,0,0" IsChecked="{Binding IsFilterEnabled}">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox
                                                Width="16"
                                                Height="16"
                                                Focusable="False">
                                                <Canvas
                                                    Width="24"
                                                    Height="24"
                                                    Focusable="False">
                                                    <Path
                                                        Data="M10,13V11H18V13H10M10,19V17H14V19H10M10,7V5H22V7H10M6,17H8.5L5,20.5L1.5,17H4V7H1.5L5,3.5L8.5,7H6V17Z"
                                                        Fill="{actipro:ThemeResource ButtonForegroundBrush}"
                                                        Focusable="False" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Title]}" />
                                        </StackPanel>
                                    </CheckBox>
                            </Menu>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <!-- One window, three states: Setup → Scanning → Review (stage 2) -->
                                <views:SetupView Grid.RowSpan="2" IsVisible="{Binding IsSetupState}" />
                                <views:ScanningView Grid.RowSpan="2" IsVisible="{Binding IsScanningState}" />
                                <Grid
                                    x:Name="GridFilter"
                                    Grid.Row="0"
                                    Background="{actipro:ThemeResource Container3BackgroundBrush}">
                                    <!-- The new results view brings its own always-on filter toolbar;
                                         this classic filter bar only applies to the DataGrid view. -->
                                    <Grid.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="IsFilterEnabled" />
                                            <Binding Path="IsReviewState" />
                                            <Binding Source="{x:Static Settings:SettingsFile.Instance}" Path="UseClassicResultsView" />
                                        </MultiBinding>
                                    </Grid.IsVisible>
                                    <WrapPanel
                                    Margin="5">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Path]}" />
                                        <TextBox
                                            MinWidth="150"
                                            Margin="5,0,0,0"
                                            Text="{Binding FilterByPath}"
                                            ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.PathNote]}" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Sort]}" />
                                        <ComboBox
                                            MinWidth="150"
                                            Margin="5,0,0,0"
                                            ItemsSource="{Binding SortOrders}"
                                            SelectedItem="{Binding SortOrder}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="Settings:SortOrderOption">
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Type]}" />
                                        <ComboBox
                                            MinWidth="150"
                                            Margin="5,0,0,0"
                                            ItemsSource="{Binding TypeFilters}"
                                            SelectedItem="{Binding FileType}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="Settings:FileTypeFilterOption">
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Similarity]}" />
                                        <NumericUpDown
                                            Width="140"
                                            FormatString="\{0\}%"
                                            Maximum="100"
                                            Minimum="0"
                                            Value="{Binding FilterSimilarityFrom}" />
                                        <TextBlock
                                            Margin="5,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.To]}" />
                                        <NumericUpDown
                                            Width="140"
                                            FormatString="\{0\}%"
                                            Maximum="100"
                                            Minimum="0"
                                            Value="{Binding FilterSimilarityTo}" />
                                        <CheckBox
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding FilterGroupsWithCheckedItems}">
                                            <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.GroupsWithCheckedItems]}" />
                                        </CheckBox>
                                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.8"
                                                Foreground="{actipro:ThemeResource ControlForegroundBrushSoftWarning}"
                                                Text="⚠ " />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.8"
                                                Foreground="{actipro:ThemeResource ControlForegroundBrushSoftWarning}"
                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Filter.Note]}" />
                                        </StackPanel>
                                    </WrapPanel>
                                </Grid>
                                <Grid Grid.Row="1" IsVisible="{Binding IsReviewState}">
                                    <views:DuplicateResultsView
                                        x:Name="NewResultsView"
                                        IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=!UseClassicResultsView}" />
                                    <DataGrid
                                        Name="dataGridGrouping"
                                        CanUserResizeColumns="True"
                                        LoadingRowGroup="OnLoadingRowGroup"
                                        IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=UseClassicResultsView}"
                                        >
                                        <!-- KeyBindings are applied programmatically by KeyboardShortcutManager -->
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <CheckBox Margin="0,0,5,0" HorizontalAlignment="Center" IsChecked="{Binding Checked}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="24">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <Button Padding="2" Margin="0" MinWidth="18" MinHeight="18" Width="18" Height="18"
                                                                Background="Transparent" BorderThickness="0"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Command="{Binding $parent[DataGrid].((vm:MainWindowVM)DataContext).RemoveSingleItemCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListOnly]}">
                                                            <TextBlock Text="✕" FontSize="10" Opacity="0.4" />
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Thumbnail" Tag="Thumbnail" IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowThumbnailColumn}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <Grid>
                                                            <!-- Skeleton shimmer while thumbnail is loading -->
                                                            <Border Classes="skeleton-shimmer"
                                                                    Width="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ThumbnailMaxWidth}"
                                                                    Height="56"
                                                                    Margin="4"
                                                                    Background="#18808080">
                                                                <Border.IsVisible>
                                                                    <MultiBinding Converter="{StaticResource ShowSkeletonConverter}">
                                                                        <Binding Path="Thumbnail" />
                                                                        <Binding Source="{x:Static Settings:SettingsFile.Instance}" Path="GeneratePreviewThumbnails" />
                                                                    </MultiBinding>
                                                                </Border.IsVisible>
                                                            </Border>
                                                            <!-- Actual thumbnail -->
                                                            <!-- DownOnly: never upscale. Without it, a single-image strip (near-square
                                                                 aspect) blows up to the full column width after a view refresh, while
                                                                 video strips (N thumbnails wide) stay small (issue #787). -->
                                                            <Image
                                                                Name="ThumbnailImage"
                                                                Source="{Binding Thumbnail}"
                                                                Stretch="Uniform"
                                                                StretchDirection="DownOnly"
                                                                HorizontalAlignment="Left"
                                                                ToolTip.Tip="{Binding ItemInfo.Path}">
                                                                <i:Interaction.Behaviors>
                                                                    <ic:ExecuteCommandOnDoubleTappedBehavior Command="{Binding $parent[DataGrid].((vm:MainWindowVM)DataContext).ThumbnailDoubleClickCommand}" />
                                                                </i:Interaction.Behaviors>
                                                            </Image>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn
                                                Width="1*"
                                                Header="Path"
                                                Tag="Path"
                                                IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowPathColumn}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                                            <!-- Tombstone: content the user already deleted; its fingerprint matched again -->
                                                            <Border IsVisible="{Binding IsTombstone}"
                                                                    Background="#B33A2E" CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[DupList.AlreadyDeletedTooltip]}">
                                                                <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[DupList.AlreadyDeleted]}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="White" />
                                                            </Border>
                                                            <!-- Offline: the file's drive is not currently mounted -->
                                                            <Border IsVisible="{Binding IsOffline}"
                                                                    Background="#555555" CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[DupList.OfflineTooltip]}">
                                                                <TextBlock Text="{Binding Source={x:Static local:App.Lang}, Path=[DupList.Offline]}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="#DDDDDD" />
                                                            </Border>
                                                            <TextBlock
                                                                Text="{Binding ItemInfo.Path, TargetNullValue=''}"
                                                                TextWrapping="Wrap"
                                                                VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="1*" IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowDurationColumn}">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock
                                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.DurationCompact]}"
                                                        ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.DurationCompactTip]}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <Grid Margin="10,0,0,0">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock
                                                                Grid.Row="0"
                                                                Margin="2"
                                                                IsVisible="{Binding ItemInfo.IsImage}"
                                                                Text="{Binding ItemInfo.Format, TargetNullValue='', Mode=OneWay}"
                                                                TextWrapping="Wrap" />
                                                            <Border Grid.Row="0" Tag="duration" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited"
                                                                    IsVisible="{Binding !ItemInfo.IsImage}">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}" ConverterParameter="{}{0:hh\:mm\:ss}">
                                                                            <Binding Path="ItemInfo.Duration" />
                                                                            <Binding Path="DurationDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestDuration" />
                                                                            <Binding Path="DurationDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Grid.Row="1" Tag="framesize" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}">
                                                                            <Binding Path="ItemInfo.FrameSize" />
                                                                            <Binding Path="FrameSizeDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestFrameSize" />
                                                                            <Binding Path="FrameSizeDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Grid.Row="2" Tag="size" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}">
                                                                            <Binding Path="ItemInfo.Size" />
                                                                            <Binding Path="SizeDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestSize" />
                                                                            <Binding Path="SizeDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock
                                                                Grid.Row="3"
                                                                Margin="2"
                                                                Text="{Binding ItemInfo.DateCreated, TargetNullValue='', Converter={StaticResource ExtraShortDateTimeConverter}}"
                                                                TextWrapping="Wrap" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="1*" IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowFormatColumn}">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock
                                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.VideoCompact]}"
                                                        ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.VideoCompactTip]}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <Grid Margin="10,0,0,0" IsVisible="{Binding !ItemInfo.IsImage}">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock
                                                                Grid.Row="0"
                                                                Margin="2"
                                                                Text="{Binding ItemInfo.Format, TargetNullValue='', Mode=OneWay}"
                                                                TextWrapping="Wrap" />
                                                            <Border Grid.Row="1" Tag="fps" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}" ConverterParameter="{}{0} fps">
                                                                            <Binding Path="ItemInfo.Fps" />
                                                                            <Binding Path="FpsDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestFps" />
                                                                            <Binding Path="FpsDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Grid.Row="2" Tag="bitrate" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}" ConverterParameter="{}{0} kbps">
                                                                            <Binding Path="ItemInfo.BitRateKbs" />
                                                                            <Binding Path="BitRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestBitRateKbs" />
                                                                            <Binding Path="BitRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock
                                                                Grid.Row="3"
                                                                Margin="2"
                                                                Foreground="{Binding ItemInfo.IsBestHdrFormat, Converter={StaticResource IsBestConverter}}"
                                                                Text="{Binding ItemInfo.HdrFormat, TargetNullValue=''}"
                                                                TextWrapping="Wrap" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="1*" IsVisible="{Binding Source={x:Static Settings:SettingsFile.Instance}, Path=ShowAudioColumn}">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock
                                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.AudioCompact]}"
                                                        ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[DuplicateList.Header.AudioCompactTip]}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="vm:DuplicateItemVM">
                                                        <Grid Margin="10,0,0,0" IsVisible="{Binding !ItemInfo.IsImage}">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock
                                                                Grid.Row="0"
                                                                Margin="2"
                                                                Text="{Binding ItemInfo.AudioFormat, TargetNullValue=''}"
                                                                TextWrapping="Wrap" />
                                                            <TextBlock
                                                                Grid.Row="1"
                                                                Margin="2"
                                                                Text="{Binding ItemInfo.AudioChannel, TargetNullValue=''}"
                                                                TextWrapping="Wrap" />
                                                            <Border Grid.Row="2" Tag="audiosamplerate" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}">
                                                                            <Binding Path="ItemInfo.AudioSampleRate" />
                                                                            <Binding Path="AudioSampleRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestAudioSampleRate" />
                                                                            <Binding Path="AudioSampleRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Grid.Row="3" Tag="audiobitrate" Background="Transparent"
                                                                    PointerEntered="OnMetricPointerEntered" PointerExited="OnMetricPointerExited">
                                                                <TextBlock Margin="2" Classes="metric-diff" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource MetricDisplayConverter}" ConverterParameter="{}{0} kbps">
                                                                            <Binding Path="ItemInfo.AudioBitRateKbs" />
                                                                            <Binding Path="AudioBitRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource MetricDiffForegroundConverter}">
                                                                            <Binding Path="ItemInfo.IsBestAudioBitRateKbs" />
                                                                            <Binding Path="AudioBitRateDiff" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
