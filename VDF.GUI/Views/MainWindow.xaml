                                                    <MenuItem Command="{Binding RemoveCheckedItemsFromListCommand}" InputGesture="{Binding Source={x:Static Settings:KeyboardShortcutManager.Instance}, Path=[DeleteCheckedItemsWithPrompt]}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListOnly]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding RemoveCheckedItemsFromListAndBlacklistCommand}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListAndExclude]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding CreateSymbolLinksForCheckedItemsCommand}" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.SymbolLinkTooltip]}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListAndSymbolLinks]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding CreateSymbolLinksForCheckedItemsAndBlacklistCommand}" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.SymbolLinkTooltip]}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListSymbolLinksExclude]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding CreateHardLinksForCheckedItemsCommand}" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.HardLinkTooltip]}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListAndHardLinks]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding CreateHardLinksForCheckedItemsAndBlacklistCommand}" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.HardLinkTooltip]}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Viewbox Width="16" Height="16">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock
                                                                    Margin="5,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.RemoveFromListHardLinksExclude]}" />
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Command="{Binding CopyCheckedItemsCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CopyToFolderEllipsis]}" />
                                                    <MenuItem Command="{Binding MoveCheckedItemsCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.MoveToFolderEllipsis]}" />
                                                    <Separator />
                                                    <MenuItem Command="{Binding LoadThumbnailsForCheckedItemsCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.LoadThumbnailsForCheckedItems]}" />
                                                </MenuItem>
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Viewbox Width="16" Height="16">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="M23 15H11.707l2.646 2.646-.707.707L9.793 14.5l3.854-3.854.707.707L11.707 14H23zm-13-5H6v1h4zm-4 5h2v-1H6zM3 4h3V3h3a2 2 0 0 1 4 0h3v1h3v9h-1V5h-2v2H6V5H4v16h14v-5h1v6H3zm4 2h8V4h-3V2.615A.615.615 0 0 0 11.386 2h-.771a.615.615 0 0 0-.615.615V4H7zM6 19h4v-1H6z" Fill="{actipro:ThemeResource ButtonForegroundBrush}" />
                                                                </Canvas>
                                                            </Viewbox>
                                                            <TextBlock
                                                                Margin="5,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Text="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Copy]}" />
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding CopyPathsToClipboardCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CopyPaths]}" />
                                                    <MenuItem Command="{Binding CopyFilenamesToClipboardCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CopyFilenames]}" />
                                                </MenuItem>
                                                <MenuItem Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.Groups]}">
                                                    <MenuItem Command="{Binding ExpandAllGroupsCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.ExpandAll]}" />
                                                    <MenuItem Command="{Binding CollapseAllGroupsCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CollapseAll]}" />
                                                </MenuItem>
                                                <MenuItem Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.SelectedGroup]}">
                                                    <MenuItem
                                                        Command="{Binding MarkGroupAsNotAMatchCommand}"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.MarkNotMatch]}"
                                                        InputGesture="{Binding Source={x:Static Settings:KeyboardShortcutManager.Instance}, Path=[MarkGroupAsNotAMatch]}"
                                                        ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.MarkNotMatchTooltip]}" />
                                                    <MenuItem
                                                        Command="{Binding OpenGroupCommand}"
                                                        CommandParameter="0"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.OpenGroup]}"
                                                        IsVisible="{Binding IsMultiOpenSupported}" />
                                                    <MenuItem
                                                        Command="{Binding OpenGroupCommand}"
                                                        CommandParameter="1"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.OpenGroupInFolder]}"
                                                        IsVisible="{Binding IsMultiOpenInFolderSupported}" />
                                                    <MenuItem Command="{Binding LoadThumbnailsForGroupCommand}" Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.LoadThumbnailsForGroup]}" />
                                                    <MenuItem
                                                        Command="{Binding ShowGroupInThumbnailComparerCommand}"
                                                        Header="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.ContextMenu.CompareFullsizeThumbnails]}"
                                                        InputGesture="{Binding Source={x:Static Settings:KeyboardShortcutManager.Instance}, Path=[ShowGroupInThumbnailComparer]}" />
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                    </DataGrid>
                                    <!-- The old empty-state overlay is superseded by the Setup state. -->
                                </Grid>
                            </Grid>
                            <WrapPanel Grid.Row="2" Margin="0,2,0,0">
                                <!-- Statistics -->
                                <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding !!Duplicates.Count}" VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.CheckedDuplicates]}" />
                                        <Run Text="{Binding DuplicatesCheckedCounter, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.CheckedSize]}" />
                                        <Run Text="{Binding DuplicatesCheckedSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.Duplicates]}" />
                                        <Run Text="{Binding TotalDuplicates, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateGroups]}" />
                                        <Run Text="{Binding TotalDuplicateGroups, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.DuplicateSize]}" />
                                        <Run Text="{Binding TotalDuplicatesSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" ToolTip.Tip="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.PotentialSavingsTooltip]}">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.PotentialSavings]}" />
                                        <Run Text="{Binding PotentialSavings, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.SizeRemoved]}" />
                                        <Run Text="{Binding TotalSizeRemoved, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <!-- Progress info -->
                                <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <!-- Thumbnail progress: determinate once the engine reports counts (#791);
                                         indeterminate only in the startup moment before the first event. -->
                                    <StackPanel Orientation="Horizontal" IsVisible="{Binding ShowThumbnailRetrievalProgress}" Margin="0,0,8,0">
                                        <ProgressBar MinWidth="60" Height="12"
                                            IsIndeterminate="{Binding !ThumbnailProgressMax}"
                                            Maximum="{Binding ThumbnailProgressMax, Mode=OneWay}"
                                            Value="{Binding ThumbnailProgressCurrent, Mode=OneWay}" />
                                        <TextBlock FontSize="12" Margin="4,0" Text="{Binding ThumbnailRetrievalProgressText}" />
                                        <Border Width="1" Margin="5,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    </StackPanel>
                                    <!-- Scan progress -->
                                    <ProgressBar Name="PbScanProgress" MinWidth="80" Height="12"
                                        Maximum="{Binding ScanProgressMaxValue, Mode=OneWay}"
                                        Value="{Binding ScanProgressValue, Mode=OneWay}" />
                                    <TextBlock FontSize="12" Margin="6,0,2,0" VerticalAlignment="Center"
                                        IsVisible="{Binding IsScanning}"
                                        Text="{Binding ScanProgressCount, Mode=OneWay}" />
                                    <TextBlock FontSize="12" Margin="4,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.ElapsedTime]}" />
                                        <Run Text="{Binding TimeElapsed, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0">
                                        <Run Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Stats.RemainingTime]}" />
                                        <Run Text="{Binding RemainingTime, Mode=OneWay}" />
                                    </TextBlock>
                                    <Border Width="1" Margin="3,2" Background="{actipro:ThemeResource ButtonForegroundBrush}" />
                                    <TextBlock FontSize="12" Margin="2,0" Text="{Binding ScanProgressText, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" MaxWidth="500" />
                                </StackPanel>
                            </WrapPanel>
                            <Grid
                                x:Name="BusyIndicator"
                                Grid.RowSpan="3"
                                Opacity="0.8">
                                <!-- Scans render in the window center (Scanning state) — the busy
                                     curtain only covers non-scan operations (delete, import, …). -->
                                <Grid.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="IsBusy" />
                                        <Binding Path="!IsScanning" />
                                    </MultiBinding>
                                </Grid.IsVisible>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar
                                        Height="10"
                                        MaxWidth="200"
                                        BorderBrush="LimeGreen"
                                        BorderThickness="1"
                                        IsIndeterminate="{Binding IsBusy}" />
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="ExtraBold"
                                        Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Busy.PleaseWait]}" />
                                    <TextBlock
                                        Name="LblBusyIndicator"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Text="{Binding IsBusyOverlayText}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Name="TabItemSettings">
                        <TabItem.Header>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Settings]}" />
                        </TabItem.Header>
                        <views:SettingsView />
                    </TabItem>
                    <TabItem Name="TabItemLog">
                        <TabItem.Header>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding Source={x:Static local:App.Lang}, Path=[MainWindow.Tab.Log]}" />
                        </TabItem.Header>
                        <views:LogView />
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>


</Window>
