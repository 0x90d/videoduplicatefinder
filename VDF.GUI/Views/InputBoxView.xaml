<Window
    x:Class="VDF.GUI.Views.InputBoxView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mvvm="clr-namespace:VDF.GUI.Mvvm;assembly=VDF.GUI"
    xmlns:local="clr-namespace:VDF.GUI;assembly=VDF.GUI"
    xmlns:vm="using:VDF.GUI.ViewModels"
    x:DataType="vm:InputBoxVM"
    Title="{Binding Title}"
    MinWidth="400"
    Width="400"
    MaxWidth="600"
    CanResize="false"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
        <StackPanel IsVisible="{Binding HasReadOnlyInfo}">
            <TextBlock
                FontSize="11"
                Opacity="0.6"
                Text="Current file:" />
            <SelectableTextBlock
                Margin="0,2,0,0"
                Text="{Binding ReadOnlyInfo}"
                TextWrapping="Wrap" />
        </StackPanel>
        <TextBox
            x:Name="TextBoxInput"
            Text="{Binding Input}"
            TextWrapping="Wrap"
            PlaceholderText="{Binding WaterMark}" />
        <StackPanel
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                MinWidth="100"
                Classes="accent"
                Command="{Binding OKCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.OK]}"
                IsDefault="{Binding HasOKButton}"
                IsVisible="{Binding HasOKButton}" />
            <Button
                MinWidth="100"
                Classes="accent"
                Command="{Binding YesCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Yes]}"
                IsDefault="{Binding HasYesButton}"
                IsVisible="{Binding HasYesButton}" />
            <Button
                MinWidth="100"
                Command="{Binding NoCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.No]}"
                IsCancel="{Binding HasNoButton}"
                IsVisible="{Binding HasNoButton}" />
            <Button
                MinWidth="100"
                Command="{Binding CancelCommand}"
                Content="{Binding Source={x:Static local:App.Lang}, Path=[Dialog.Cancel]}"
                IsCancel="{Binding HasCancelButton}"
                IsVisible="{Binding HasCancelButton}" />
        </StackPanel>
    </StackPanel>
</Window>