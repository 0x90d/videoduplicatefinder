<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui">

    <!-- Hover effect on group header buttons -->
    <Style Selector="DataGridRowGroupHeader Button.group-action">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{actipro:ThemeResource Container3BorderBrush}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="DataGridRowGroupHeader Button.group-action:pointerover">
        <Setter Property="Background" Value="{actipro:ThemeResource Container3BackgroundBrush}" />
        <Setter Property="Opacity" Value="1" />
    </Style>
</Styles>
