<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataGrid row hover: subtle background highlight + elevation -->
    <Style Selector="DataGridRow">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource RowHoverBackground}" />
    </Style>


    <!-- Metric hover diff: smooth color transition (matches web's transition: color 0.15s) -->
    <Style Selector="TextBlock.metric-diff">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Skeleton shimmer loading animation for thumbnails -->
    <Style Selector="Border.skeleton-shimmer">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="40" />
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="CubicEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.7" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>
